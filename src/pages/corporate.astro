---
import Layout from '../layouts/Layout.astro';
export const prerender = true;
---
<Layout title="Corporate Gifting | One Earth Gifting" description="Sustainable corporate gifts for teams, clients and events. Volume discounts from 10 units. Custom branding. Dedicated account manager.">

  <div class="corp-hero">
    <div class="container">
      <p class="eyebrow" style="color:rgba(255,255,255,0.55);margin-bottom:0.75rem;">One Earth Gifting | Corporate</p>
      <h1>Sustainable gifts your clients will love</h1>
      <p>Ethically sourced, beautifully packaged and carbon conscious. From client appreciation to employee recognition. We make corporate gifting effortless and meaningful.</p>
      <a href="#enquiry" class="btn btn-terracotta">Get a Quote →</a>
    </div>
  </div>

  <div class="corp-trust-row">
    <div class="container">
      <div class="corp-trust-inner">
        {['10 to 10,000 units','Bulk fulfilment UK wide','Branded packaging','Dedicated account manager','Sustainability reporting','Same week quotes'].map(i => (
          <span class="corp-trust-item">✓ {i}</span>
        ))}
      </div>
    </div>
  </div>

  <!-- Pricing -->
  <section class="corp-form-section" id="pricing">
    <div class="container" style="max-width:860px;">
      <p class="eyebrow">Transparent pricing</p>
      <h2>Volume discounts</h2>
      <p style="margin-bottom:2rem;">Discounts apply automatically to verified trade accounts. All pricing is based on standard retail prices.</p>
      <div style="overflow-x:auto;border-radius:var(--radius-md);overflow:hidden;box-shadow:var(--shadow-sm);">
        <table style="width:100%;border-collapse:collapse;font-family:var(--font-primary);font-size:0.86rem;">
          <thead>
            <tr style="background:var(--forest);color:var(--white);">
              <th style="padding:1rem;text-align:left;">Units</th>
              <th style="padding:1rem;text-align:left;">Discount</th>
              <th style="padding:1rem;text-align:left;">Delivery</th>
              <th style="padding:1rem;text-align:left;">Branding</th>
            </tr>
          </thead>
          <tbody>
            {[
              ['10 to 49','10% off','Standard 3 to 5 days','Gift card included'],
              ['50 to 199','20% off','Express available','Logo on packaging and gift card'],
              ['200 plus','Custom pricing','Direct to recipient','Full custom packaging'],
              ['Annual contract','POA','Scheduled deliveries','Dedicated manager'],
            ].map(([units,disc,del,brand],i) => (
              <tr style={i % 2 === 1 ? 'background:var(--sand);' : ''}>
                <td style="padding:1rem;">{units}</td>
                <td style={`padding:1rem;font-weight:700;color:${i < 2 ? 'var(--forest)' : 'var(--terracotta)'}`}>{disc}</td>
                <td style="padding:1rem;">{del}</td>
                <td style="padding:1rem;">{brand}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Occasions -->
  <section style="background:var(--sand);padding:4rem 0;">
    <div class="container" style="max-width:900px;">
      <p class="eyebrow">Perfect for</p>
      <h2>Every gifting occasion</h2>
      <div class="occasion-grid">
        {['Client Appreciation','Employee Wellbeing','Event Gifts','Seasonal Campaigns','Product Launches','Onboarding Kits','Award Gifts','Partner Thank Yous'].map(o => (
          <div class="occasion-item">{o}</div>
        ))}
      </div>
    </div>
  </section>

  <!-- Enquiry form -->
  <section class="corp-form-section" id="enquiry">
    <div class="container" style="max-width:840px;">
      <p class="eyebrow">Get started</p>
      <h2>Request a quote</h2>
      <p>Tell us about your requirements and we'll come back within one business day with a tailored proposal.</p>

      <form class="corp-form" id="corp-form" style="margin-top:2rem;" novalidate>
        <div class="form-row">
          <div class="form-group">
            <label for="co-name">Company name *</label>
            <input type="text" id="co-name" name="company" required placeholder="Acme Ltd">
          </div>
          <div class="form-group">
            <label for="co-contact">Contact name *</label>
            <input type="text" id="co-contact" name="contact" required placeholder="Jane Smith">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="co-email">Email address *</label>
            <input type="email" id="co-email" name="email" required placeholder="jane@company.com">
          </div>
          <div class="form-group">
            <label for="co-phone">Phone</label>
            <input type="tel" id="co-phone" name="phone" placeholder="+44 7700 900000">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="co-qty">Estimated quantity *</label>
            <select id="co-qty" name="quantity" required>
              <option value="">Select range</option>
              <option>10 to 49 units</option>
              <option>50 to 199 units</option>
              <option>200 to 499 units</option>
              <option>500 to 999 units</option>
              <option>1,000+ units</option>
            </select>
          </div>
          <div class="form-group">
            <label for="co-occ">Occasion *</label>
            <select id="co-occ" name="occasion" required>
              <option value="">Select occasion</option>
              <option>Client appreciation</option>
              <option>Employee recognition</option>
              <option>Event / conference</option>
              <option>Seasonal campaign</option>
              <option>Product launch</option>
              <option>Onboarding kit</option>
              <option>Other</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label>Custom branding required?</label>
          <div class="radio-group">
            <label class="radio-label"><input type="radio" name="branding" value="yes"> Yes</label>
            <label class="radio-label"><input type="radio" name="branding" value="no"> No</label>
          </div>
        </div>
        <div class="form-group">
          <label for="co-msg">Additional notes</label>
          <textarea id="co-msg" name="message" placeholder="Specific products, budget, delivery dates, or other requirements..."></textarea>
        </div>
        <div id="form-status"></div>
        <button type="submit" class="btn btn-primary" style="min-width:200px;">Send Enquiry →</button>
      </form>
    </div>
  </section>

</Layout>

<script>
  document.getElementById('corp-form')?.addEventListener('submit', async e => {
    e.preventDefault();
    const form = e.target;
    const btn = form.querySelector('button[type=submit]');
    const status = document.getElementById('form-status');
    const data = Object.fromEntries(new FormData(form));

    // Basic validation
    const required = ['company','contact','email','quantity','occasion'];
    const missing = required.filter(k => !data[k]);
    if (missing.length) {
      status.innerHTML = '<p style="color:#c0392b;font-family:var(--font-primary);margin-bottom:1rem;">Please fill in all required fields.</p>';
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Sending…';

    try {
      const res = await fetch('/api/corporate-enquiry', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (res.ok) {
        status.innerHTML = '<div class="form-success">✓ Enquiry received! We\'ll be in touch within one business day.</div>';
        form.reset();
      } else {
        throw new Error('Server error');
      }
    } catch {
      // Fallback — mailto
      const subject = `Corporate Gifting Enquiry from ${data.company}`;
      const body = Object.entries(data).map(([k,v]) => `${k}: ${v}`).join('\n');
      window.location.href = `mailto:hello@oneearthgifting.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    } finally {
      btn.disabled = false;
      btn.textContent = 'Send Enquiry →';
    }
  });
</script>
