---
import Layout from '../layouts/Layout.astro';
import { products, categories } from '../data/products.js';
export const prerender = true;
---
<Layout title="One Earth Gifting — Sustainable Gifts for People Who Care">

  <!-- Hero -->
  <section class="hero" aria-label="Hero">
    <div class="hero__media">
      <video autoplay muted loop playsinline id="hero-video">
        <source src="/video/HeroVideo.mp4" type="video/mp4">
        <!-- fallback image if video fails -->
        <img src="/images/EarthTonesCollection3.jpg" alt="One Earth Gifting — sustainable gift collection" loading="eager">
      </video>
    </div>
    <div class="hero__overlay" aria-hidden="true"></div>
    <div class="container">
      <div class="hero__content">
        <p class="hero__eyebrow">🌿 Sustainably sourced · Ethically made</p>
        <h1 class="hero__headline">Gifts that do <em>good</em></h1>
        <p class="hero__sub">Curated sustainable gifts for individuals and businesses. Every product hand-picked for quality, ethics, and beauty — packaged with the planet in mind.</p>
        <div class="hero__ctas">
          <a href="/shop" class="btn btn-terracotta">Shop Now</a>
          <a href="/corporate" class="btn btn-outline">Corporate Enquiry</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Category filter + products -->
  <section class="products-section" id="shop">
    <div class="category-filter" role="navigation" aria-label="Filter by category">
      <div class="container">
        <div class="category-filter__inner">
          {categories.map(c => (
            <button
              class={`filter-btn${c.slug === 'all' ? ' active' : ''}`}
              data-filter={c.slug}
              aria-pressed={c.slug === 'all' ? 'true' : 'false'}
            >{c.name}</button>
          ))}
        </div>
      </div>
    </div>

    <div class="container" style="padding-top:3rem;padding-bottom:3rem;">
      <div class="products-section__header">
        <div>
          <p class="eyebrow">Curated collection</p>
          <h2>Thoughtfully sourced gifts</h2>
        </div>
        <a href="/shop" class="btn btn-ghost btn-sm">View all</a>
      </div>

      <div class="products-grid" id="products-grid">
        {products.slice(0, 8).map(product => (
          <div class="product-item visible" data-category={product.categorySlug} data-tags={product.tags.join(',')}>
            <article class="product-card">
              <div class="product-card__img">
                {product.images[0] ? (
                  <a href={`/products/${product.slug}`} tabindex="-1" aria-hidden="true">
                    <img
                      src={`/images/${product.images[0]}`}
                      alt={product.name}
                      loading="lazy"
                      width="600" height="450"
                      onerror="this.parentElement.innerHTML='<div class=\'product-card__img-placeholder\'><svg width=\'40\' height=\'40\' viewBox=\'0 0 24 24\' fill=\'none\' stroke=\'#ccc\' stroke-width=\'1.5\'><rect x=\'3\' y=\'3\' width=\'18\' height=\'18\' rx=\'2\'/><circle cx=\'8.5\' cy=\'8.5\' r=\'1.5\'/><polyline points=\'21 15 16 10 5 21\'/></svg></div>'"
                    >
                  </a>
                ) : (
                  <div class="product-card__img-placeholder">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                  </div>
                )}
                <button
                  class="product-card__wishlist"
                  data-slug={product.slug}
                  aria-label={`Save ${product.name} to wishlist`}
                  onclick={`toggleWishlist('${product.slug}', this)`}
                >
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                </button>
              </div>
              <div class="product-card__body">
                <p class="product-card__cat">{product.category}</p>
                <h3 class="product-card__name"><a href={`/products/${product.slug}`}>{product.name}</a></h3>
                <p class="product-card__desc">{product.description}</p>
                <div class="product-card__footer">
                  <span class="product-card__price">£{product.price.toFixed(2)}</span>
                  <button
                    class="btn btn-primary btn-sm"
                    onclick={`addToCart({slug:'${product.slug}',name:'${product.name.replace(/'/g,"\\'")}',price:${product.price},image:'/images/${product.images[0] || ''}'})`}
                    aria-label={`Add ${product.name} to basket`}
                  >
                    Add to Basket
                  </button>
                </div>
              </div>
            </article>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Corporate section -->
  <section class="corporate-section" id="corporate" aria-label="Corporate gifting">
    <div class="container">
      <div class="corporate-section__grid">
        <div>
          <p class="eyebrow corp-eyebrow">For businesses</p>
          <h2 class="corp-heading">Corporate gifting, made simple</h2>
          <p class="corp-sub">From 10 to 10,000 units — branded, curated, delivered. We handle everything so your team, clients, and partners feel truly valued.</p>
          <table class="volume-table" aria-label="Volume pricing">
            <thead>
              <tr><th>Units</th><th>Discount</th><th>Best for</th></tr>
            </thead>
            <tbody>
              <tr><td>10–49</td><td class="hl">10% off</td><td>Small teams & events</td></tr>
              <tr><td>50–199</td><td class="hl">20% off</td><td>Corporate campaigns</td></tr>
              <tr><td>200+</td><td class="hl">Custom pricing</td><td>Enterprise & annual</td></tr>
            </tbody>
          </table>
          <div class="corp-ctas">
            <a href="/corporate" class="btn btn-terracotta">Get a Quote</a>
            <a href="/corporate#pricing" class="btn btn-outline">View all tiers</a>
          </div>
        </div>
        <div>
          <div class="b2b-features">
            {[
              ['🎁','Custom Branding','Your logo on packaging, ribbons, and gift cards'],
              ['🚚','Bulk Fulfilment','Palletised or direct-to-recipient delivery UK-wide'],
              ['🌿','Sustainability Report','Impact certificate per order — great for ESG reporting'],
              ['🤝','Dedicated Manager','Named account manager for all orders 50+'],
            ].map(([icon,title,sub]) => (
              <div class="b2b-feat">
                <div class="b2b-feat__icon" aria-hidden="true">{icon}</div>
                <div>
                  <div class="b2b-feat__title">{title}</div>
                  <div class="b2b-feat__sub">{sub}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust strip -->
  <section class="trust-strip" aria-label="Our commitments">
    <div class="container">
      <div class="trust-strip__grid">
        {[
          ['🌍','1% for the Planet','1% of every sale donated to environmental causes'],
          ['📦','Plastic-Free Packaging','100% compostable, recycled or reusable packaging'],
          ['🚚','Free UK Delivery','Free standard delivery on all orders over £40'],
          ['⭐','Verified Reviews','4.9★ from hundreds of verified customers'],
        ].map(([icon,title,sub]) => (
          <div class="trust-item">
            <div class="trust-item__icon" aria-hidden="true">{icon}</div>
            <h3 class="trust-item__title">{title}</h3>
            <p class="trust-item__sub">{sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="newsletter" aria-label="Newsletter signup">
    <div class="container">
      <p class="eyebrow" style="color:rgba(255,255,255,0.55);margin-bottom:0.5rem;">Stay in the loop</p>
      <h2>Thoughtful gifts, straight to your inbox</h2>
      <p>New arrivals, seasonal picks, B2B offers and sustainability stories — no spam, ever.</p>
      <form class="newsletter-form" id="nl-form" aria-label="Newsletter signup">
        <input type="email" placeholder="your@email.com" required aria-label="Email address" autocomplete="email">
        <button type="submit" class="btn btn-terracotta">Subscribe</button>
      </form>
      <p class="newsletter-note">
        By subscribing you agree to our <a href="/privacy">Privacy Policy</a>. Unsubscribe anytime.
      </p>
    </div>
  </section>

</Layout>

<script>
  // Category filter
  const filterBtns = document.querySelectorAll('.filter-btn');
  const productItems = document.querySelectorAll('.product-item');

  function applyFilter(cat) {
    filterBtns.forEach(b => {
      b.classList.toggle('active', b.dataset.filter === cat);
      b.setAttribute('aria-pressed', String(b.dataset.filter === cat));
    });
    productItems.forEach(item => {
      const match = cat === 'all'
        || item.dataset.category === cat
        || (item.dataset.tags || '').split(',').includes(cat);
      item.classList.toggle('visible', match);
    });
  }

  filterBtns.forEach(btn => btn.addEventListener('click', () => applyFilter(btn.dataset.filter)));

  // Newsletter
  document.getElementById('nl-form')?.addEventListener('submit', e => {
    e.preventDefault();
    const btn = e.target.querySelector('button');
    btn.textContent = '✓ Subscribed!';
    btn.disabled = true;
  });

  // Init wishlist states
  document.querySelectorAll('.product-card__wishlist').forEach(btn => {
    if (window.isWishlisted?.(btn.dataset.slug)) btn.classList.add('active');
  });
</script>
