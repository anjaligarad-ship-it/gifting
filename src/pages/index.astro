---
import Layout from '../layouts/Layout.astro';
export const prerender = true;
---
<Layout title="One Earth Gifting | Sustainable Gifts for People Who Care">

  <!-- Hero -->
  <section class="hero" aria-label="Hero">
    <div class="hero__media">
      <picture>
        <source media="(max-width: 768px)" srcset="/images/Hero(2).png">
        <img src="/images/Hero (1).png" alt="One Earth Gifting" loading="eager">
      </picture>
    </div>
    <div class="hero__content">
      <div class="hero__ctas">
        <a href="/shop" class="btn btn-terracotta">Shop Now</a>
        <a href="/corporate" class="btn btn-outline">Corporate Enquiry</a>
      </div>
    </div>
  </section>

  <!-- Brand story -->
  <section class="brand-story">
    <div class="container">
      <p class="brand-story__tagline">Gifts that do good</p>
      <p class="brand-story__text">We believe the best gifts carry meaning. Every product in our collection is handpicked for quality, ethics and beauty. Sourced from fairly paid makers, wrapped in plastic free packaging and made to be kept rather than forgotten.</p>
    </div>
  </section>

  <!-- Collection banner -->
  <section class="collection-banner" aria-label="Explore our collection">
    <img src="/images/EarthtonesCollection4.png" alt="One Earth Gifting collection" class="collection-banner__img" loading="lazy">
    <div class="collection-banner__overlay" aria-hidden="true"></div>
    <div class="collection-banner__content">
      <a href="/shop" class="btn btn-outline" style="font-size:0.9rem;padding:1rem 2.4rem;letter-spacing:0.14em;">Explore Our Latest Collections</a>
    </div>
  </section>

  <!-- Announcement ribbon + B2B banner — homepage only, above For Business -->
  <div class="announcement-bar" aria-label="Site announcements">
    <div class="announcement-bar__track">
      <span class="announcement-bar__item">🌿 Free UK delivery on orders of 20 or more items</span>
      <span class="announcement-bar__item">📦 B2B bulk discounts from 10 units. <a href="/corporate" style="color:rgba(255,255,255,0.8);text-decoration:underline;">Get a Quote</a></span>
      <span class="announcement-bar__item">🌳 One tree planted with every order</span>
      <span class="announcement-bar__item">♻️ All packaging plastic free and compostable</span>
      <span class="announcement-bar__item" aria-hidden="true">🌿 Free UK delivery on orders of 20 or more items</span>
      <span class="announcement-bar__item" aria-hidden="true">📦 B2B bulk discounts from 10 units. <a href="/corporate" style="color:rgba(255,255,255,0.8);text-decoration:underline;">Get a Quote</a></span>
      <span class="announcement-bar__item" aria-hidden="true">🌳 One tree planted with every order</span>
      <span class="announcement-bar__item" aria-hidden="true">♻️ All packaging plastic free and compostable</span>
    </div>
  </div>
  <div class="b2b-banner" role="complementary" aria-label="Corporate gifting offer">
    <div class="b2b-banner__inner">
      <p class="b2b-banner__text">🏢 Corporate clients: <strong>20% off 50+ units</strong>. Custom branded orders, bulk fulfilment and a dedicated account manager</p>
      <a href="/corporate" class="btn btn-terracotta btn-sm">Get a Quote</a>
    </div>
  </div>

  <!-- Corporate section -->
  <section class="corporate-section" id="corporate" aria-label="Corporate gifting">
    <div class="container">
      <div class="corporate-section__grid">
        <div>
          <p class="eyebrow corp-eyebrow">For businesses</p>
          <h2 class="corp-heading">Corporate gifting, made simple</h2>
          <p class="corp-sub">From 10 to 10,000 units. Branded, curated and delivered. We handle everything so your team, clients and partners feel truly valued.</p>
          <table class="volume-table" aria-label="Volume pricing">
            <thead>
              <tr><th>Units</th><th>Discount</th><th>Best for</th></tr>
            </thead>
            <tbody>
              <tr><td>10 to 49</td><td class="hl">10% off</td><td>Small teams and events</td></tr>
              <tr><td>50 to 199</td><td class="hl">20% off</td><td>Corporate campaigns</td></tr>
              <tr><td>200 plus</td><td class="hl">Custom pricing</td><td>Enterprise and annual</td></tr>
            </tbody>
          </table>
          <div class="corp-ctas">
            <a href="/corporate" class="btn btn-terracotta">Get a Quote</a>
            <a href="/corporate#pricing" class="btn btn-outline">View all tiers</a>
          </div>
        </div>
        <div>
          <div class="b2b-features">
            {[
              ['🎁','Custom Branding','Your logo on packaging and gift cards'],
              ['🚚','Bulk Fulfilment','Palletised or direct-to-recipient delivery UK-wide'],
              ['🌿','Sustainability Report','Impact certificate per order. Great for ESG reporting'],
              ['🤝','Dedicated Manager','Named account manager for all orders 50+'],
            ].map(([icon,title,sub]) => (
              <div class="b2b-feat">
                <div class="b2b-feat__icon" aria-hidden="true">{icon}</div>
                <div>
                  <div class="b2b-feat__title">{title}</div>
                  <div class="b2b-feat__sub">{sub}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust strip -->
  <section class="trust-strip" aria-label="Our commitments">
    <div class="container">
      <div class="trust-strip__grid">
        {[
          ['🌳','A Tree Per Order','One tree planted per sale through local NGO partners in Asia'],
          ['📦','Plastic-Free Packaging','100% compostable, recycled or reusable packaging'],
          ['🚚','Free UK Delivery','Free standard delivery on all orders of 20 or more items'],
          ['⭐','Verified Reviews','4.9★ from hundreds of verified customers'],
        ].map(([icon,title,sub]) => (
          <div class="trust-item">
            <div class="trust-item__icon" aria-hidden="true">{icon}</div>
            <h3 class="trust-item__title">{title}</h3>
            <p class="trust-item__sub">{sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="newsletter" aria-label="Newsletter signup">
    <div class="container">
      <p class="eyebrow" style="color:rgba(255,255,255,0.55);margin-bottom:0.5rem;">Stay in the loop</p>
      <h2>Thoughtful gifts, straight to your inbox</h2>
      <p>New arrivals, seasonal picks, B2B offers and sustainability stories. No spam, ever.</p>
      <form class="newsletter-form" id="nl-form" aria-label="Newsletter signup">
        <input type="email" placeholder="your@email.com" required aria-label="Email address" autocomplete="email">
        <button type="submit" class="btn btn-terracotta">Subscribe</button>
      </form>
      <p class="newsletter-note">
        By subscribing you agree to our <a href="/privacy">Privacy Policy</a>. Unsubscribe anytime.
      </p>
    </div>
  </section>

</Layout>

<script>
  // Newsletter
  document.getElementById('nl-form')?.addEventListener('submit', e => {
    e.preventDefault();
    const btn = e.target.querySelector('button');
    btn.textContent = '✓ Subscribed!';
    btn.disabled = true;
  });
</script>
