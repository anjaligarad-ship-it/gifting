---
import Layout from '../layouts/Layout.astro';
export const prerender = true;
---
<Layout title="Your Basket | One Earth Gifting">
  <div class="container" style="padding:3rem 0;max-width:760px;">
    <h1 style="margin-bottom:2rem;">Your Basket</h1>
    <div id="cart-page-items"></div>

    <div id="cart-page-form-section" style="margin-top:3rem;display:none;">
      <div id="cart-page-login-prompt" hidden style="text-align:center;padding:2.5rem 1.5rem;background:var(--sand);border-radius:var(--radius-md);">
        <p style="margin-bottom:1.25rem;font-family:var(--font-primary);font-weight:600;">Please log in to continue to checkout</p>
        <button type="button" id="cart-page-google-btn" class="btn btn-ghost" style="justify-content:center;align-items:center;gap:0.55rem;margin:0 auto;">
          <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
            <path fill="#4285F4" d="M17.64 9.2c0-.64-.06-1.25-.16-1.84H9v3.48h4.84c-.21 1.13-.85 2.09-1.81 2.73v2.27h2.92c1.71-1.57 2.69-3.89 2.69-6.64z"/>
            <path fill="#34A853" d="M9 18c2.43 0 4.47-.8 5.96-2.18l-2.92-2.27c-.81.54-1.85.87-3.04.87-2.34 0-4.32-1.58-5.03-3.71H.96v2.33C2.44 15.98 5.48 18 9 18z"/>
            <path fill="#FBBC05" d="M3.97 10.71c-.18-.54-.28-1.11-.28-1.71s.1-1.17.28-1.71V4.96H.96A8.99 8.99 0 0 0 0 9c0 1.45.35 2.83.96 4.04l3.01-2.33z"/>
            <path fill="#EA4335" d="M9 3.58c1.32 0 2.5.45 3.44 1.35l2.59-2.59C13.46.89 11.43 0 9 0 5.48 0 2.44 2.02.96 4.96l3.01 2.33C4.68 5.16 6.66 3.58 9 3.58z"/>
          </svg>
          Login with Google
        </button>
        <p style="margin-top:1rem;font-size:0.85rem;">or <a href="/login?redirect=/cart" style="color:var(--forest);font-weight:600;">log in with email</a></p>
      </div>

      <div id="cart-page-form-wrap" hidden>
        <h2 style="margin-bottom:1.5rem;">Delivery Details</h2>
        <div class="corp-form">
          <div class="form-group">
            <label for="cp-name">Full name *</label>
            <input type="text" id="cp-name" required autocomplete="name">
          </div>
          <div class="form-group">
            <label for="cp-email">Email *</label>
            <input type="email" id="cp-email" required autocomplete="email">
          </div>
          <div class="form-group">
            <label for="cp-phone">Contact number *</label>
            <input type="tel" id="cp-phone" required autocomplete="tel">
          </div>
          <!-- Gift toggle (G2) -->
          <div style="margin:1.25rem 0;padding:1rem;background:var(--sand);border-radius:var(--radius-md);">
            <label style="display:flex;align-items:center;gap:0.65rem;cursor:pointer;font-weight:600;">
              <input type="checkbox" id="cp-is-gift" style="width:1.1rem;height:1.1rem;cursor:pointer;">
              🎁 This is a gift — send to a different address
            </label>
          </div>

          <!-- Billing / delivery address (used when not a gift) -->
          <div id="cp-billing-section">
            <h3 style="font-size:0.95rem;font-weight:700;margin-bottom:0.75rem;color:var(--text-dark);">Delivery Address</h3>
          </div>
          <div class="form-group">
            <label for="cp-addr-line1">Address line 1 *</label>
            <input type="text" id="cp-addr-line1" required autocomplete="address-line1" placeholder="House number and street">
            <p class="field-error" id="cp-addr-line1-err" style="color:#c0392b;font-size:0.8rem;margin:0.2rem 0 0;display:none;"></p>
          </div>
          <div class="form-group">
            <label for="cp-addr-line2">Address line 2 <span style="font-weight:400;color:var(--text-light);">(optional)</span></label>
            <input type="text" id="cp-addr-line2" autocomplete="address-line2" placeholder="Flat, apartment, etc.">
          </div>
          <div class="form-group">
            <label for="cp-addr-town">Town / City *</label>
            <input type="text" id="cp-addr-town" required autocomplete="address-level2">
            <p class="field-error" id="cp-addr-town-err" style="color:#c0392b;font-size:0.8rem;margin:0.2rem 0 0;display:none;"></p>
          </div>
          <div class="form-group">
            <label for="cp-addr-postcode">Postcode *</label>
            <input type="text" id="cp-addr-postcode" required autocomplete="postal-code" placeholder="e.g. CV1 1GU" style="text-transform:uppercase;max-width:180px;">
            <p class="field-error" id="cp-addr-postcode-err" style="color:#c0392b;font-size:0.8rem;margin:0.2rem 0 0;display:none;"></p>
          </div>
          <!-- Gift message + hide prices (G3/G4 — shown when gift toggle is on) -->
          <div id="cp-gift-extras" style="display:none;margin-top:0.75rem;">
            <div class="form-group">
              <label for="cp-gift-message">Gift message <span style="font-weight:400;color:var(--text-light);">(optional, printed on card)</span></label>
              <textarea id="cp-gift-message" maxlength="250" rows="3" placeholder="Write a personal message for the recipient…" style="resize:vertical;"></textarea>
              <p id="cp-gift-message-counter" style="font-size:0.78rem;color:var(--text-light);text-align:right;margin:0.2rem 0 0;">0 / 250</p>
            </div>
            <label style="display:flex;align-items:center;gap:0.65rem;cursor:pointer;font-size:0.9rem;margin-top:0.5rem;">
              <input type="checkbox" id="cp-hide-price" style="width:1rem;height:1rem;cursor:pointer;">
              Hide prices on packing slip (gift receipt)
            </label>
          </div>

          <!-- Recipient address (G2 — shown when gift toggle is on) -->
          <div id="cp-recipient-section" style="display:none;margin-top:1.5rem;padding:1rem;border:1.5px solid var(--forest);border-radius:var(--radius-md);">
            <h3 style="font-size:0.95rem;font-weight:700;margin-bottom:0.75rem;color:var(--forest);">🎁 Recipient's Delivery Address</h3>
            <div class="form-group">
              <label for="cp-rec-name">Recipient's name *</label>
              <input type="text" id="cp-rec-name" autocomplete="off">
            </div>
            <div class="form-group">
              <label for="cp-rec-line1">Address line 1 *</label>
              <input type="text" id="cp-rec-line1" autocomplete="off" placeholder="House number and street">
              <p class="field-error" id="cp-rec-line1-err" style="color:#c0392b;font-size:0.8rem;margin:0.2rem 0 0;display:none;"></p>
            </div>
            <div class="form-group">
              <label for="cp-rec-line2">Address line 2 <span style="font-weight:400;color:var(--text-light);">(optional)</span></label>
              <input type="text" id="cp-rec-line2" autocomplete="off" placeholder="Flat, apartment, etc.">
            </div>
            <div class="form-group">
              <label for="cp-rec-town">Town / City *</label>
              <input type="text" id="cp-rec-town" autocomplete="off">
              <p class="field-error" id="cp-rec-town-err" style="color:#c0392b;font-size:0.8rem;margin:0.2rem 0 0;display:none;"></p>
            </div>
            <div class="form-group">
              <label for="cp-rec-postcode">Postcode *</label>
              <input type="text" id="cp-rec-postcode" autocomplete="off" placeholder="e.g. M1 1AE" style="text-transform:uppercase;max-width:180px;">
              <p class="field-error" id="cp-rec-postcode-err" style="color:#c0392b;font-size:0.8rem;margin:0.2rem 0 0;display:none;"></p>
            </div>
          </div>

          <!-- Delivery options (C1) -->
          <div id="cp-delivery-section" style="margin-top:1.75rem;">
            <h3 style="font-size:0.95rem;font-weight:700;margin-bottom:0.75rem;color:var(--text-dark);">Delivery</h3>
            <div id="cp-delivery-options" style="display:flex;flex-direction:column;gap:0.6rem;"></div>
            <p id="cp-delivery-free-note" style="display:none;font-size:0.82rem;color:#2d7a3a;font-weight:600;margin-top:0.4rem;">🌿 Free delivery on this order</p>
          </div>

          <!-- Promo code entry -->
          <div style="margin-top:1rem;">
            <label for="cp-promo-input" style="font-size:0.85rem;font-weight:600;display:block;margin-bottom:0.4rem;">Promotion Code</label>
            <div style="display:flex;gap:0.5rem;">
              <input type="text" id="cp-promo-input" placeholder="Enter code" autocomplete="off"
                style="flex:1;padding:0.55rem 0.8rem;border:1px solid var(--border);border-radius:var(--radius-sm);font-size:0.95rem;text-transform:uppercase;letter-spacing:0.05em;">
              <button type="button" id="cp-promo-apply-btn" class="btn btn-ghost" style="white-space:nowrap;padding:0.55rem 1rem;">Apply</button>
            </div>
            <p id="cp-promo-msg" style="font-size:0.82rem;margin:0.4rem 0 0;min-height:1.1em;"></p>
          </div>

          <!-- Applied promo banner (shown only after a valid Apply) -->
          <div id="cp-promo-applied" style="display:none;margin-top:0.75rem;padding:0.85rem 1rem;background:#e8f5e9;border:1.5px solid #4caf50;border-radius:var(--radius-md);align-items:center;justify-content:space-between;gap:0.5rem;">
            <div>
              <div id="cp-promo-applied-label" style="font-family:var(--font-primary);font-weight:700;font-size:0.95rem;color:#2d7a3a;"></div>
              <div style="font-size:0.8rem;color:#388e3c;margin-top:0.1rem;">Discount shown below</div>
            </div>
            <button type="button" id="cp-promo-remove-btn" style="font-size:0.78rem;color:#888;background:none;border:none;cursor:pointer;text-decoration:underline;white-space:nowrap;">Remove</button>
          </div>

          <!-- Price breakdown -->
          <div style="margin-top:1rem;border-top:1px solid var(--border);padding-top:1rem;display:flex;flex-direction:column;gap:0.45rem;">
            <div style="display:flex;justify-content:space-between;font-size:0.95rem;color:var(--text-light);">
              <span>Subtotal</span>
              <span id="cp-subtotal">£0.00</span>
            </div>
            <div id="cp-shipping-row" style="display:flex;justify-content:space-between;font-size:0.95rem;color:var(--text-light);">
              <span id="cp-shipping-label">Delivery</span>
              <span id="cp-shipping-price">—</span>
            </div>
            <div id="cp-discount-row" style="display:none;justify-content:space-between;font-size:0.95rem;font-weight:600;color:#2d7a3a;">
              <span id="cp-discount-label">Discount</span>
              <span id="cp-promo-discount"></span>
            </div>
            <div style="display:flex;justify-content:space-between;font-family:var(--font-primary);font-size:1.15rem;font-weight:700;border-top:2px solid var(--border);padding-top:0.6rem;margin-top:0.1rem;">
              <span>Total to pay</span>
              <span id="cp-total">£0.00</span>
            </div>
          </div>
          <button type="button" class="btn btn-primary cart-checkout-btn" id="cp-checkout-btn">Pay with Card →</button>
          <p class="cart-secure">🔒 Secure checkout via Stripe · Free returns · Plastic-free packaging</p>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { supabase } from '../lib/supabaseClient.js';

  const $ = id => document.getElementById(id);
  function fmt(n) { return '£' + n.toFixed(2).replace(/\.00$/, ''); }
  function getCart() { try { return JSON.parse(localStorage.getItem('oeg_cart') || '[]'); } catch { return []; } }
  function saveCart(c) { try { localStorage.setItem('oeg_cart', JSON.stringify(c)); } catch {} }
  function getNote() { try { return localStorage.getItem('oeg_note') || ''; } catch { return ''; } }
  function getCustomer() { try { return JSON.parse(localStorage.getItem('oeg_customer') || '{}'); } catch { return {}; } }
  function saveCustomer(c) { try { localStorage.setItem('oeg_customer', JSON.stringify(c)); } catch {} }

  // ── Delivery config (mirrors src/lib/delivery.js) ──────────────────────────
  const SHIPPING_OPTIONS = [
    { id: 'standard', label: 'Standard delivery', days: 5, price: 395, subtitle: '3–5 working days' },
    { id: 'express',  label: 'Express delivery',  days: 2, price: 695, subtitle: '1–2 working days' },
  ];
  const FREE_DELIVERY_VALUE  = 50;
  const FREE_DELIVERY_ITEMS  = 20;
  const SPECIAL_ZONES = { BT:2, IV:2, HS:2, KW:2, ZE:2, GY:2, JE:2, IM:2 };

  let selectedShippingId = 'standard';

  function isDeliveryFree(subtotal, itemCount) {
    return subtotal >= FREE_DELIVERY_VALUE || itemCount >= FREE_DELIVERY_ITEMS;
  }

  function specialExtraDays(postcode) {
    if (!postcode) return 0;
    const prefix = postcode.trim().toUpperCase().replace(/\d.*$/, '');
    return SPECIAL_ZONES[prefix] ?? 0;
  }

  function addWorkingDays(startDate, n) {
    let d = new Date(startDate);
    while (n > 0) {
      d.setDate(d.getDate() + 1);
      const wd = d.toLocaleDateString('en-GB', { timeZone: 'Europe/London', weekday: 'short' });
      if (wd !== 'Sat' && wd !== 'Sun') n--;
    }
    return d;
  }

  function arrivalLabel(opt, postcode) {
    const dispatch = addWorkingDays(new Date(), 1);
    const total = opt.days + specialExtraDays(postcode);
    const arrival = addWorkingDays(dispatch, total);
    return arrival.toLocaleDateString('en-GB', {
      timeZone: 'Europe/London', weekday: 'long', day: 'numeric', month: 'long',
    });
  }

  function renderDeliveryOptions() {
    const container = $('cp-delivery-options');
    const freeNote  = $('cp-delivery-free-note');
    if (!container) return;

    const cart      = getCart();
    const subtotal  = cart.reduce((s, i) => s + i.price * i.qty, 0);
    const itemCount = cart.reduce((s, i) => s + i.qty, 0);
    const free      = isDeliveryFree(subtotal, itemCount);
    const postcode  = $('cp-addr-postcode')?.value.trim() || '';

    if (freeNote) freeNote.style.display = free ? 'block' : 'none';

    container.innerHTML = SHIPPING_OPTIONS.map(opt => {
      const effectivePrice = free ? 0 : opt.price;
      const priceStr = effectivePrice === 0 ? 'Free' : `£${(effectivePrice / 100).toFixed(2)}`;
      const arrStr   = arrivalLabel(opt, postcode);
      const checked  = selectedShippingId === opt.id;
      return `
        <label class="delivery-option${checked ? ' selected' : ''}" data-id="${opt.id}" style="display:flex;align-items:center;gap:0.85rem;padding:0.85rem 1rem;border:1.5px solid ${checked ? 'var(--forest)' : 'var(--border)'};border-radius:var(--radius-md);cursor:pointer;background:${checked ? 'color-mix(in srgb,var(--forest) 6%,white)' : 'transparent'};">
          <input type="radio" name="cp-delivery" value="${opt.id}" ${checked ? 'checked' : ''} style="accent-color:var(--forest);width:1.1rem;height:1.1rem;">
          <div style="flex:1;">
            <div style="font-weight:600;font-size:0.92rem;">${opt.label} <span style="font-weight:400;color:var(--text-light);font-size:0.85rem;">· ${opt.subtitle}</span></div>
            <div style="font-size:0.8rem;color:var(--text-light);margin-top:0.15rem;">Arrives by ${arrStr}</div>
          </div>
          <div style="font-weight:700;font-size:0.95rem;color:${effectivePrice === 0 ? '#2d7a3a' : 'var(--text-dark)'};">${priceStr}</div>
        </label>`;
    }).join('');

    container.querySelectorAll('input[name="cp-delivery"]').forEach(radio => {
      radio.addEventListener('change', () => {
        selectedShippingId = radio.value;
        renderDeliveryOptions();
        updateForm();
      });
    });
  }

  // Applied promo state — session-only, re-validated server-side at checkout
  let appliedPromoCode = null;
  let appliedDiscountRate = 0;
  let appliedDiscountCap = 0;

  async function applyPromoCode(code) {
    const msg = $('cp-promo-msg');
    if (!code) { if (msg) msg.textContent = 'Please enter a promo code.'; return; }
    const applyBtn = $('cp-promo-apply-btn');
    if (applyBtn) { applyBtn.disabled = true; applyBtn.textContent = 'Checking…'; }
    if (msg) { msg.style.color = '#666'; msg.textContent = ''; }

    try {
      const res = await fetch('/api/promo/apply', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ code }),
      });
      const data = await res.json();

      if (data.valid) {
        appliedPromoCode = data.code;
        appliedDiscountRate = data.discountRate;
        appliedDiscountCap = data.discountCap;
        if (msg) { msg.style.color = '#2d7a3a'; msg.textContent = ''; }
        updateForm();
      } else {
        if (msg) { msg.style.color = '#c0392b'; msg.textContent = data.error || 'Invalid promo code.'; }
      }
    } catch {
      if (msg) { msg.style.color = '#c0392b'; msg.textContent = 'Could not check code — please try again.'; }
    }
    if (applyBtn) { applyBtn.disabled = false; applyBtn.textContent = 'Apply'; }
  }

  function removePromoCode() {
    appliedPromoCode = null;
    appliedDiscountRate = 0;
    appliedDiscountCap = 0;
    const input = $('cp-promo-input');
    const msg = $('cp-promo-msg');
    if (input) input.value = '';
    if (msg) msg.textContent = '';
    updateForm();
  }

  function toast(msg, type = 'success') {
    const t = $('toast');
    if (!t) { alert(msg); return; }
    t.textContent = msg;
    t.className = `toast ${type}`;
    requestAnimationFrame(() => {
      t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), 2800);
    });
  }

  let session = null;

  function renderItems() {
    const cart = getCart();
    const el = $('cart-page-items');
    if (cart.length === 0) {
      el.innerHTML = '<p style="text-align:center;padding:3rem 0;color:var(--text-light);font-style:italic;">Your cart is empty — Pick sustainable gifts for your loved ones!</p>';
      return;
    }
    const total = cart.reduce((s, i) => s + i.price * i.qty, 0);
    el.innerHTML = cart.map(item => `
      <div class="cart-item" data-slug="${item.slug}">
        <img class="cart-item__img" src="${item.image}" alt="${item.name}" loading="lazy" onerror="this.style.display='none'">
        <div class="cart-item__details">
          <div class="cart-item__name">${item.name}</div>
          <div class="cart-item__price">${fmt(item.price * item.qty)}</div>
          <div class="cart-item__qty">
            <button class="qty-btn" data-action="dec" data-slug="${item.slug}" aria-label="Remove one">−</button>
            <span class="qty-val">${item.qty}</span>
            <button class="qty-btn" data-action="inc" data-slug="${item.slug}" aria-label="Add one">+</button>
          </div>
          <button class="cart-item__remove" data-slug="${item.slug}">Remove</button>
        </div>
      </div>`).join('') + `
      `;

    el.querySelectorAll('.qty-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const cart = getCart();
        const idx = cart.findIndex(i => i.slug === btn.dataset.slug);
        if (idx === -1) return;
        if (btn.dataset.action === 'inc') cart[idx].qty++;
        else cart[idx].qty--;
        if (cart[idx].qty <= 0) cart.splice(idx, 1);
        saveCart(cart);
        window.updateBadge?.();
        renderItems();
        updateForm();
      });
    });
    el.querySelectorAll('.cart-item__remove').forEach(btn => {
      btn.addEventListener('click', () => {
        const cart = getCart().filter(i => i.slug !== btn.dataset.slug);
        saveCart(cart);
        window.updateBadge?.();
        renderItems();
        updateForm();
      });
    });
  }

  function updateForm() {
    const cart = getCart();
    const hasItems = cart.length > 0;
    $('cart-page-form-section').style.display = hasItems ? '' : 'none';
    if (!hasItems) return;

    if (!session) {
      $('cart-page-login-prompt').hidden = false;
      $('cart-page-form-wrap').hidden = true;
      return;
    }

    $('cart-page-login-prompt').hidden = true;
    $('cart-page-form-wrap').hidden = false;
    renderDeliveryOptions();
    const subtotal  = cart.reduce((s, i) => s + i.price * i.qty, 0);
    const itemCount = cart.reduce((s, i) => s + i.qty, 0);
    const free      = isDeliveryFree(subtotal, itemCount);
    const selOpt    = SHIPPING_OPTIONS.find(o => o.id === selectedShippingId) || SHIPPING_OPTIONS[0];
    const shippingPence = free ? 0 : selOpt.price;
    const shipping  = shippingPence / 100;

    const discountPence = appliedPromoCode
      ? Math.round(Math.min(subtotal * appliedDiscountRate, appliedDiscountCap) * 100)
      : 0;
    const discount = discountPence / 100;
    const total = Math.max(0, subtotal - discount + shipping);

    $('cp-subtotal').textContent = fmt(subtotal);

    const shippingPriceEl = $('cp-shipping-price');
    const shippingLabelEl = $('cp-shipping-label');
    if (shippingPriceEl) shippingPriceEl.textContent = shippingPence === 0 ? 'Free' : fmt(shipping);
    if (shippingLabelEl) shippingLabelEl.textContent = selOpt.label;

    const promoApplied = $('cp-promo-applied');
    const discountRow = $('cp-discount-row');
    if (appliedPromoCode) {
      const pct = Math.round(appliedDiscountRate * 100);
      if ($('cp-promo-applied-label')) $('cp-promo-applied-label').textContent = `🎉 Code ${appliedPromoCode} applied — ${pct}% off!`;
      if ($('cp-discount-label')) $('cp-discount-label').textContent = `Discount (${appliedPromoCode})`;
      $('cp-promo-discount').textContent = `-${fmt(discount)}`;
      if (promoApplied) promoApplied.style.display = 'flex';
      if (discountRow) discountRow.style.display = 'flex';
    } else {
      if (promoApplied) promoApplied.style.display = 'none';
      if (discountRow) discountRow.style.display = 'none';
    }

    $('cp-total').textContent = fmt(total);

    const c = getCustomer();
    if ($('cp-name') && !$('cp-name').value) $('cp-name').value = c.name || session.user.user_metadata?.full_name || '';
    if ($('cp-email') && !$('cp-email').value) $('cp-email').value = c.email || session.user.email || '';
    if ($('cp-phone') && !$('cp-phone').value) $('cp-phone').value = c.phone || '';
    if ($('cp-addr-line1') && !$('cp-addr-line1').value) $('cp-addr-line1').value = c.address?.line1 || '';
    if ($('cp-addr-line2') && !$('cp-addr-line2').value) $('cp-addr-line2').value = c.address?.line2 || '';
    if ($('cp-addr-town') && !$('cp-addr-town').value) $('cp-addr-town').value = c.address?.town || '';
    if ($('cp-addr-postcode') && !$('cp-addr-postcode').value) $('cp-addr-postcode').value = c.address?.postcode || '';
  }

  // UK postcode regex — mirrors server-side address.js
  const UK_PC_RE = /^([A-Z]{1,2}\d[A-Z\d]?)\s*(\d[A-Z]{2})$/i;
  function normalisePostcode(raw) {
    if (!raw) return null;
    const m = raw.trim().replace(/\s+/g, ' ').match(UK_PC_RE);
    return m ? `${m[1].toUpperCase()} ${m[2].toUpperCase()}` : null;
  }

  function showFieldError(fieldId, msg) {
    const el = $(`${fieldId}-err`);
    if (el) { el.textContent = msg; el.style.display = msg ? 'block' : 'none'; }
  }

  // Gift toggle (G2/G3/G4)
  $('cp-is-gift')?.addEventListener('change', () => {
    const isGift = $('cp-is-gift').checked;
    $('cp-recipient-section').style.display = isGift ? 'block' : 'none';
    $('cp-gift-extras').style.display = isGift ? 'block' : 'none';
  });

  // Gift message char counter (G3)
  $('cp-gift-message')?.addEventListener('input', () => {
    const len = $('cp-gift-message').value.length;
    const counter = $('cp-gift-message-counter');
    if (counter) {
      counter.textContent = `${len} / 250`;
      counter.style.color = len > 230 ? '#c0392b' : 'var(--text-light)';
    }
  });

  // Validate postcode format inline on blur
  $('cp-addr-postcode')?.addEventListener('blur', () => {
    const raw = $('cp-addr-postcode')?.value;
    const norm = normalisePostcode(raw);
    if (norm) {
      $('cp-addr-postcode').value = norm;
      showFieldError('cp-addr-postcode', '');
    } else if (raw?.trim()) {
      showFieldError('cp-addr-postcode', 'Enter a valid UK postcode (e.g. CV1 1GU)');
    }
    renderDeliveryOptions(); // refresh arrival date when postcode changes
  });

  function readForm() {
    const isGift = $('cp-is-gift')?.checked || false;
    const form = {
      name: $('cp-name')?.value.trim() || '',
      email: $('cp-email')?.value.trim() || '',
      phone: $('cp-phone')?.value.trim() || '',
      isGift,
      address: {
        line1: $('cp-addr-line1')?.value.trim() || '',
        line2: $('cp-addr-line2')?.value.trim() || '',
        town: $('cp-addr-town')?.value.trim() || '',
        postcode: normalisePostcode($('cp-addr-postcode')?.value) || $('cp-addr-postcode')?.value.trim() || '',
      },
    };
    if (isGift) {
      form.giftMessage = $('cp-gift-message')?.value.trim() || '';
      form.hidePrice = $('cp-hide-price')?.checked || false;
      form.recipientAddress = {
        name: $('cp-rec-name')?.value.trim() || '',
        line1: $('cp-rec-line1')?.value.trim() || '',
        line2: $('cp-rec-line2')?.value.trim() || '',
        town: $('cp-rec-town')?.value.trim() || '',
        postcode: normalisePostcode($('cp-rec-postcode')?.value) || $('cp-rec-postcode')?.value.trim() || '',
      };
    }
    return form;
  }
  ['cp-name', 'cp-email', 'cp-phone', 'cp-addr-line1', 'cp-addr-line2', 'cp-addr-town', 'cp-addr-postcode'].forEach(id => {
    $(id)?.addEventListener('change', () => saveCustomer(readForm()));
  });

  $('cp-promo-apply-btn')?.addEventListener('click', () => applyPromoCode($('cp-promo-input')?.value.trim().toUpperCase()));
  $('cp-promo-input')?.addEventListener('keydown', e => { if (e.key === 'Enter') applyPromoCode($('cp-promo-input').value.trim().toUpperCase()); });
  $('cp-promo-remove-btn')?.addEventListener('click', removePromoCode);

  $('cart-page-google-btn')?.addEventListener('click', async () => {
    const btn = $('cart-page-google-btn');
    btn.disabled = true;
    btn.textContent = 'Redirecting to Google…';
    const { error } = await supabase.auth.signInWithOAuth({
      provider: 'google',
      options: { redirectTo: `${window.location.origin}/auth/callback?redirect=/cart` },
    });
    if (error) {
      btn.disabled = false;
      btn.innerHTML = 'Continue with Google';
      toast('Google sign-in failed: ' + error.message, 'error');
    }
  });

  $('cp-checkout-btn')?.addEventListener('click', async () => {
    const cart = getCart();
    if (cart.length === 0) { toast('Your basket is empty', 'error'); return; }
    const customer = readForm();
    let hasErrors = false;
    if (!customer.name) { toast('Please enter your full name', 'error'); return; }
    if (!customer.email || !/^\S+@\S+\.\S+$/.test(customer.email)) { toast('Please enter a valid email address', 'error'); return; }
    if (!customer.phone) { toast('Please enter your contact number', 'error'); return; }
    if (!customer.address.line1) { showFieldError('cp-addr-line1', 'Address line 1 is required'); hasErrors = true; }
    if (!customer.address.town) { showFieldError('cp-addr-town', 'Town / city is required'); hasErrors = true; }
    const normPC = normalisePostcode(customer.address.postcode);
    if (!normPC) { showFieldError('cp-addr-postcode', 'Enter a valid UK postcode (e.g. CV1 1GU)'); hasErrors = true; }
    if (customer.isGift && customer.recipientAddress) {
      if (!customer.recipientAddress.line1) { showFieldError('cp-rec-line1', 'Recipient address line 1 is required'); hasErrors = true; }
      if (!customer.recipientAddress.town) { showFieldError('cp-rec-town', 'Recipient town / city is required'); hasErrors = true; }
      const normRecPC = normalisePostcode(customer.recipientAddress.postcode);
      if (!normRecPC) { showFieldError('cp-rec-postcode', 'Enter a valid UK postcode'); hasErrors = true; }
      else customer.recipientAddress.postcode = normRecPC;
    }
    if (hasErrors) { toast('Please fix the address errors above', 'error'); return; }
    customer.address.postcode = normPC;
    saveCustomer(customer);

    const btn = $('cp-checkout-btn');
    btn.disabled = true;
    btn.textContent = 'Redirecting…';
    try {
      const res = await fetch('/api/create-checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          items: cart, note: getNote(), customer,
          isGift: customer.isGift || false,
          recipientAddress: customer.recipientAddress || null,
          giftMessage: customer.giftMessage || '',
          hidePrice: customer.hidePrice || false,
          selectedShippingId,
          userId: session?.user?.id || null, userEmail: session?.user?.email || null,
          promoCode: appliedPromoCode || null,
        }),
      });
      const { url, error } = await res.json();
      if (url) window.location.href = url;
      else { toast(error || 'Checkout failed — please try again', 'error'); btn.disabled = false; btn.textContent = 'Pay with Card →'; }
    } catch {
      toast('Network error — please try again', 'error');
      btn.disabled = false;
      btn.textContent = 'Pay with Card →';
    }
  });

  supabase.auth.getSession().then(({ data }) => {
    session = data.session;
    renderItems();
    updateForm();
  });
  supabase.auth.onAuthStateChange((_event, s) => {
    session = s;
    updateForm();
  });
</script>
