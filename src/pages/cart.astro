---
import Layout from '../layouts/Layout.astro';
export const prerender = true;
---
<Layout title="Your Basket | One Earth Gifting">
  <div class="container" style="padding:3rem 0;max-width:760px;">
    <h1 style="margin-bottom:2rem;">Your Basket</h1>
    <div id="cart-page-items"></div>

    <div id="cart-page-form-section" style="margin-top:3rem;display:none;">
      <div id="cart-page-login-prompt" hidden style="text-align:center;padding:2.5rem 1.5rem;background:var(--sand);border-radius:var(--radius-md);">
        <p style="margin-bottom:1.25rem;font-family:var(--font-primary);font-weight:600;">Please log in to continue to checkout</p>
        <button type="button" id="cart-page-google-btn" class="btn btn-ghost" style="justify-content:center;align-items:center;gap:0.55rem;margin:0 auto;">
          <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
            <path fill="#4285F4" d="M17.64 9.2c0-.64-.06-1.25-.16-1.84H9v3.48h4.84c-.21 1.13-.85 2.09-1.81 2.73v2.27h2.92c1.71-1.57 2.69-3.89 2.69-6.64z"/>
            <path fill="#34A853" d="M9 18c2.43 0 4.47-.8 5.96-2.18l-2.92-2.27c-.81.54-1.85.87-3.04.87-2.34 0-4.32-1.58-5.03-3.71H.96v2.33C2.44 15.98 5.48 18 9 18z"/>
            <path fill="#FBBC05" d="M3.97 10.71c-.18-.54-.28-1.11-.28-1.71s.1-1.17.28-1.71V4.96H.96A8.99 8.99 0 0 0 0 9c0 1.45.35 2.83.96 4.04l3.01-2.33z"/>
            <path fill="#EA4335" d="M9 3.58c1.32 0 2.5.45 3.44 1.35l2.59-2.59C13.46.89 11.43 0 9 0 5.48 0 2.44 2.02.96 4.96l3.01 2.33C4.68 5.16 6.66 3.58 9 3.58z"/>
          </svg>
          Login with Google
        </button>
        <p style="margin-top:1rem;font-size:0.85rem;">or <a href="/login?redirect=/cart" style="color:var(--forest);font-weight:600;">log in with email</a></p>
      </div>

      <div id="cart-page-form-wrap" hidden>
        <h2 style="margin-bottom:1.5rem;">Delivery Details</h2>
        <div class="corp-form">
          <div class="form-group">
            <label for="cp-name">Full name *</label>
            <input type="text" id="cp-name" required autocomplete="name">
          </div>
          <div class="form-group">
            <label for="cp-email">Email *</label>
            <input type="email" id="cp-email" required autocomplete="email">
          </div>
          <div class="form-group">
            <label for="cp-phone">Contact number *</label>
            <input type="tel" id="cp-phone" required autocomplete="tel">
          </div>
          <div class="form-group">
            <label for="cp-address">Delivery address *</label>
            <textarea id="cp-address" required autocomplete="street-address" placeholder="Address line, city, postcode"></textarea>
          </div>
          <!-- Promo code entry -->
          <div style="margin-top:1rem;">
            <label for="cp-promo-input" style="font-size:0.85rem;font-weight:600;display:block;margin-bottom:0.4rem;">Promotion Code</label>
            <div style="display:flex;gap:0.5rem;">
              <input type="text" id="cp-promo-input" placeholder="Enter code" autocomplete="off"
                style="flex:1;padding:0.55rem 0.8rem;border:1px solid var(--border);border-radius:var(--radius-sm);font-size:0.95rem;text-transform:uppercase;letter-spacing:0.05em;">
              <button type="button" id="cp-promo-apply-btn" class="btn btn-ghost" style="white-space:nowrap;padding:0.55rem 1rem;">Apply</button>
            </div>
            <p id="cp-promo-msg" style="font-size:0.82rem;margin:0.4rem 0 0;min-height:1.1em;"></p>
          </div>

          <!-- Applied promo banner (shown only after a valid Apply) -->
          <div id="cp-promo-applied" style="display:none;margin-top:0.75rem;padding:0.85rem 1rem;background:#e8f5e9;border:1.5px solid #4caf50;border-radius:var(--radius-md);align-items:center;justify-content:space-between;gap:0.5rem;">
            <div>
              <div id="cp-promo-applied-label" style="font-family:var(--font-primary);font-weight:700;font-size:0.95rem;color:#2d7a3a;"></div>
              <div style="font-size:0.8rem;color:#388e3c;margin-top:0.1rem;">Discount shown below</div>
            </div>
            <button type="button" id="cp-promo-remove-btn" style="font-size:0.78rem;color:#888;background:none;border:none;cursor:pointer;text-decoration:underline;white-space:nowrap;">Remove</button>
          </div>

          <!-- Price breakdown -->
          <div style="margin-top:1rem;border-top:1px solid var(--border);padding-top:1rem;display:flex;flex-direction:column;gap:0.45rem;">
            <div style="display:flex;justify-content:space-between;font-size:0.95rem;color:var(--text-light);">
              <span>Subtotal</span>
              <span id="cp-subtotal">£0.00</span>
            </div>
            <div id="cp-discount-row" style="display:none;justify-content:space-between;font-size:0.95rem;font-weight:600;color:#2d7a3a;">
              <span id="cp-discount-label">Discount</span>
              <span id="cp-promo-discount"></span>
            </div>
            <div style="display:flex;justify-content:space-between;font-family:var(--font-primary);font-size:1.15rem;font-weight:700;border-top:2px solid var(--border);padding-top:0.6rem;margin-top:0.1rem;">
              <span>Total to pay</span>
              <span id="cp-total">£0.00</span>
            </div>
            <p style="font-size:0.78rem;color:var(--text-light);margin:0;">+ shipping (selected at checkout)</p>
          </div>
          <button type="button" class="btn btn-primary cart-checkout-btn" id="cp-checkout-btn">Pay with Card →</button>
          <p class="cart-secure">🔒 Secure checkout via Stripe · Free returns · Plastic-free packaging</p>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { supabase } from '../lib/supabaseClient.js';

  const $ = id => document.getElementById(id);
  function fmt(n) { return '£' + n.toFixed(2).replace(/\.00$/, ''); }
  function getCart() { try { return JSON.parse(localStorage.getItem('oeg_cart') || '[]'); } catch { return []; } }
  function saveCart(c) { try { localStorage.setItem('oeg_cart', JSON.stringify(c)); } catch {} }
  function getNote() { try { return localStorage.getItem('oeg_note') || ''; } catch { return ''; } }
  function getCustomer() { try { return JSON.parse(localStorage.getItem('oeg_customer') || '{}'); } catch { return {}; } }
  function saveCustomer(c) { try { localStorage.setItem('oeg_customer', JSON.stringify(c)); } catch {} }

  // Applied promo state — session-only, re-validated server-side at checkout
  let appliedPromoCode = null;
  let appliedDiscountRate = 0;
  let appliedDiscountCap = 0;

  async function applyPromoCode(code) {
    const msg = $('cp-promo-msg');
    if (!code) { if (msg) msg.textContent = 'Please enter a promo code.'; return; }
    const applyBtn = $('cp-promo-apply-btn');
    if (applyBtn) { applyBtn.disabled = true; applyBtn.textContent = 'Checking…'; }
    if (msg) { msg.style.color = '#666'; msg.textContent = ''; }

    try {
      const res = await fetch('/api/promo/apply', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ code, userId: session?.user?.id }),
      });
      const data = await res.json();

      if (data.valid) {
        appliedPromoCode = data.code;
        appliedDiscountRate = data.discountRate;
        appliedDiscountCap = data.discountCap;
        if (msg) { msg.style.color = '#2d7a3a'; msg.textContent = ''; }
        updateForm();
      } else {
        if (msg) { msg.style.color = '#c0392b'; msg.textContent = data.error || 'Invalid promo code.'; }
      }
    } catch {
      if (msg) { msg.style.color = '#c0392b'; msg.textContent = 'Could not check code — please try again.'; }
    }
    if (applyBtn) { applyBtn.disabled = false; applyBtn.textContent = 'Apply'; }
  }

  function removePromoCode() {
    appliedPromoCode = null;
    appliedDiscountRate = 0;
    appliedDiscountCap = 0;
    const input = $('cp-promo-input');
    const msg = $('cp-promo-msg');
    if (input) input.value = '';
    if (msg) msg.textContent = '';
    updateForm();
  }

  function toast(msg, type = 'success') {
    const t = $('toast');
    if (!t) { alert(msg); return; }
    t.textContent = msg;
    t.className = `toast ${type}`;
    requestAnimationFrame(() => {
      t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), 2800);
    });
  }

  let session = null;

  function renderItems() {
    const cart = getCart();
    const el = $('cart-page-items');
    if (cart.length === 0) {
      el.innerHTML = '<p style="text-align:center;padding:3rem 0;color:var(--text-light);font-style:italic;">Your cart is empty — Pick sustainable gifts for your loved ones!</p>';
      return;
    }
    const total = cart.reduce((s, i) => s + i.price * i.qty, 0);
    el.innerHTML = cart.map(item => `
      <div class="cart-item" data-slug="${item.slug}">
        <img class="cart-item__img" src="${item.image}" alt="${item.name}" loading="lazy" onerror="this.style.display='none'">
        <div class="cart-item__details">
          <div class="cart-item__name">${item.name}</div>
          <div class="cart-item__price">${fmt(item.price * item.qty)}</div>
          <div class="cart-item__qty">
            <button class="qty-btn" data-action="dec" data-slug="${item.slug}" aria-label="Remove one">−</button>
            <span class="qty-val">${item.qty}</span>
            <button class="qty-btn" data-action="inc" data-slug="${item.slug}" aria-label="Add one">+</button>
          </div>
          <button class="cart-item__remove" data-slug="${item.slug}">Remove</button>
        </div>
      </div>`).join('') + `
      `;

    el.querySelectorAll('.qty-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const cart = getCart();
        const idx = cart.findIndex(i => i.slug === btn.dataset.slug);
        if (idx === -1) return;
        if (btn.dataset.action === 'inc') cart[idx].qty++;
        else cart[idx].qty--;
        if (cart[idx].qty <= 0) cart.splice(idx, 1);
        saveCart(cart);
        window.updateBadge?.();
        renderItems();
        updateForm();
      });
    });
    el.querySelectorAll('.cart-item__remove').forEach(btn => {
      btn.addEventListener('click', () => {
        const cart = getCart().filter(i => i.slug !== btn.dataset.slug);
        saveCart(cart);
        window.updateBadge?.();
        renderItems();
        updateForm();
      });
    });
  }

  function updateForm() {
    const cart = getCart();
    const hasItems = cart.length > 0;
    $('cart-page-form-section').style.display = hasItems ? '' : 'none';
    if (!hasItems) return;

    if (!session) {
      $('cart-page-login-prompt').hidden = false;
      $('cart-page-form-wrap').hidden = true;
      return;
    }

    $('cart-page-login-prompt').hidden = true;
    $('cart-page-form-wrap').hidden = false;
    const subtotal = cart.reduce((s, i) => s + i.price * i.qty, 0);

    const discountPence = appliedPromoCode
      ? Math.round(Math.min(subtotal * appliedDiscountRate, appliedDiscountCap) * 100)
      : 0;
    const discount = discountPence / 100;
    const total = Math.max(0, subtotal - discount);

    $('cp-subtotal').textContent = fmt(subtotal);

    const promoApplied = $('cp-promo-applied');
    const discountRow = $('cp-discount-row');
    if (appliedPromoCode) {
      const pct = Math.round(appliedDiscountRate * 100);
      if ($('cp-promo-applied-label')) $('cp-promo-applied-label').textContent = `🎉 Code ${appliedPromoCode} applied — ${pct}% off!`;
      if ($('cp-discount-label')) $('cp-discount-label').textContent = `Discount (${appliedPromoCode})`;
      $('cp-promo-discount').textContent = `-${fmt(discount)}`;
      if (promoApplied) promoApplied.style.display = 'flex';
      if (discountRow) discountRow.style.display = 'flex';
    } else {
      if (promoApplied) promoApplied.style.display = 'none';
      if (discountRow) discountRow.style.display = 'none';
    }

    $('cp-total').textContent = fmt(total);

    const c = getCustomer();
    if ($('cp-name') && !$('cp-name').value) $('cp-name').value = c.name || session.user.user_metadata?.full_name || '';
    if ($('cp-email') && !$('cp-email').value) $('cp-email').value = c.email || session.user.email || '';
    if ($('cp-phone') && !$('cp-phone').value) $('cp-phone').value = c.phone || '';
    if ($('cp-address') && !$('cp-address').value) $('cp-address').value = c.address || '';
  }

  function readForm() {
    return {
      name: $('cp-name')?.value.trim() || '',
      email: $('cp-email')?.value.trim() || '',
      phone: $('cp-phone')?.value.trim() || '',
      address: $('cp-address')?.value.trim() || '',
    };
  }
  ['cp-name', 'cp-email', 'cp-phone', 'cp-address'].forEach(id => {
    $(id)?.addEventListener('change', () => saveCustomer(readForm()));
  });

  $('cp-promo-apply-btn')?.addEventListener('click', () => applyPromoCode($('cp-promo-input')?.value.trim().toUpperCase()));
  $('cp-promo-input')?.addEventListener('keydown', e => { if (e.key === 'Enter') applyPromoCode($('cp-promo-input').value.trim().toUpperCase()); });
  $('cp-promo-remove-btn')?.addEventListener('click', removePromoCode);

  $('cart-page-google-btn')?.addEventListener('click', async () => {
    const btn = $('cart-page-google-btn');
    btn.disabled = true;
    btn.textContent = 'Redirecting to Google…';
    const { error } = await supabase.auth.signInWithOAuth({
      provider: 'google',
      options: { redirectTo: `${window.location.origin}/auth/callback?redirect=/cart` },
    });
    if (error) {
      btn.disabled = false;
      btn.innerHTML = 'Continue with Google';
      toast('Google sign-in failed: ' + error.message, 'error');
    }
  });

  $('cp-checkout-btn')?.addEventListener('click', async () => {
    const cart = getCart();
    if (cart.length === 0) { toast('Your basket is empty', 'error'); return; }
    const customer = readForm();
    if (!customer.name || !customer.email || !customer.phone || !customer.address) {
      toast('Please fill in your name, email, contact number and address', 'error');
      return;
    }
    if (!/^\S+@\S+\.\S+$/.test(customer.email)) {
      toast('Please enter a valid email address', 'error');
      return;
    }
    saveCustomer(customer);

    const btn = $('cp-checkout-btn');
    btn.disabled = true;
    btn.textContent = 'Redirecting…';
    try {
      const res = await fetch('/api/create-checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          items: cart, note: getNote(), customer,
          userId: session?.user?.id || null, userEmail: session?.user?.email || null,
          promoCode: appliedPromoCode || null,
        }),
      });
      const { url, error } = await res.json();
      if (url) window.location.href = url;
      else { toast(error || 'Checkout failed — please try again', 'error'); btn.disabled = false; btn.textContent = 'Pay with Card →'; }
    } catch {
      toast('Network error — please try again', 'error');
      btn.disabled = false;
      btn.textContent = 'Pay with Card →';
    }
  });

  supabase.auth.getSession().then(({ data }) => {
    session = data.session;
    renderItems();
    updateForm();
  });
  supabase.auth.onAuthStateChange((_event, s) => {
    session = s;
    updateForm();
  });
</script>
