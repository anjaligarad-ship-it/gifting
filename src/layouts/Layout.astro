---
import '../styles/global.css';
import { getVisibleProducts } from '../data/products.js';

const searchProducts = getVisibleProducts().map(p => ({
  slug: p.slug, name: p.name, category: p.category,
  price: p.price, image: p.images[0] || '', preOrder: !!p.preOrder, comingSoon: !!p.comingSoon,
}));

export interface Props {
  title?: string;
  description?: string;
  image?: string;
}
const {
  title = 'One Earth Gifting — Sustainable Gifts',
  description = 'Curated sustainable gifts for individuals and businesses. Ethically sourced, plastic free packaged. One tree planted with every order.',
  image = '/og-image.jpg',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#2D4A2D">

  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={canonical}>

  <!-- Open Graph -->
  <meta property="og:title"       content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image"       content={image}>
  <meta property="og:url"         content={canonical}>
  <meta property="og:type"        content="website">
  <meta property="og:site_name"   content="One Earth Gifting">

  <!-- Twitter card -->
  <meta name="twitter:card"        content="summary_large_image">
  <meta name="twitter:title"       content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image"       content={image}>

  <!-- Schema.org -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "One Earth Gifting",
    "url": "https://oneearthgifting.com",
    "description": "Sustainable gifting for individuals and businesses",
    "parentOrganization": {
      "@type": "Organization",
      "name": "One Earth Beyond Ltd",
      "url": "https://oneearthbeyond.com"
    }
  }
  </script>

</head>
<body>
  <a href="#main" class="visually-hidden" style="position:fixed;top:1rem;left:1rem;z-index:9999;padding:0.5rem 1rem;background:var(--forest);color:#fff;border-radius:4px;font-family:var(--font-primary);">
    Skip to content
  </a>

  <slot name="before-header" />

  <!-- Header -->
  <header class="site-header" role="banner">
    <div class="container">
      <div class="site-header__inner">
        <button class="hamburger" aria-label="Open menu" aria-expanded="false" id="menu-btn">
          <span></span><span></span><span></span>
        </button>

        <a href="/" class="site-header__logo" aria-label="One Earth Gifting — Home">
          <img src="/Logo/logo.png" alt="One Earth Gifting" class="site-logo">
        </a>

        <nav class="site-nav" aria-label="Main navigation">
          <a href="/shop">Shop</a>
          <a href="/corporate">Corporate Gifting</a>
          <a href="/about#sustainability">Sustainability</a>
          <a href="/our-artist">Our Artists</a>
        </nav>

        <div class="header-actions">
          <div class="search-menu" id="search-menu">
            <button type="button" class="icon-btn" id="search-btn" aria-label="Search" aria-haspopup="true" aria-expanded="false">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            </button>
            <div class="search-panel" id="search-panel">
              <input type="search" id="search-input" placeholder="Search products..." aria-label="Search products">
              <div id="search-results" class="search-panel__results"></div>
            </div>
          </div>
          <div class="account-menu" id="account-menu">
            <a href="/login" id="account-link" class="icon-btn" aria-label="Account" aria-haspopup="true" aria-expanded="false">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </a>
            <div class="account-dropdown" id="account-dropdown">
              <a href="/account/orders" class="account-dropdown__item">Order History</a>
              <a href="/account/wishlist" class="account-dropdown__item">Wishlist</a>
              <a href="/account/profile" class="account-dropdown__item">Profile</a>
              <button type="button" class="account-dropdown__item account-dropdown__item--danger" id="logout-trigger">Logout</button>
            </div>
          </div>
          <div class="cart-menu" id="cart-menu">
            <a href="/cart" class="icon-btn" id="cart-btn" aria-label="Open basket" aria-haspopup="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
              <span class="cart-badge" id="cart-count" data-count="0" aria-label="items in basket">0</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- Mobile Nav -->
  <nav class="mobile-nav" id="mobile-nav" aria-hidden="true" aria-label="Mobile navigation">
    <div class="mobile-nav__top">
      <img src="/Logo/logo.png" alt="One Earth Gifting" class="site-logo">
      <button class="icon-btn" id="menu-close" aria-label="Close menu">✕</button>
    </div>
    <div class="mobile-nav__links">
      <a href="/shop">Shop</a>
      <a href="/corporate">Corporate Gifting</a>
      <a href="/about#sustainability">Sustainability</a>
      <a href="/our-artist">Our Artists</a>
    </div>
    <div class="mobile-nav__cta">
      <a href="/corporate" class="btn btn-terracotta" style="width:100%;justify-content:center;">Corporate Enquiry</a>
    </div>
  </nav>

  <!-- Overlay -->
  <div class="overlay" id="overlay" aria-hidden="true"></div>

  <!-- Cart Drawer -->
  <div class="cart-drawer" id="cart-drawer" role="dialog" aria-modal="true" aria-label="Your basket">
    <div class="cart-drawer__header">
      <span class="cart-drawer__title">Your Basket</span>
      <button class="cart-drawer__close" id="cart-close" aria-label="Close basket">✕</button>
    </div>
    <div class="cart-drawer__body" id="cart-body">
      <div class="cart-empty">Your cart is empty — Pick sustainable gifts for your loved ones!</div>
    </div>
    <div class="cart-drawer__footer">
      <details class="cart-customer-form" id="cust-details">
        <summary class="cart-customer-form__summary">
          <span>Delivery Details</span>
          <svg class="cart-customer-form__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
        </summary>
        <div class="cart-customer-form__body">
          <div class="form-group">
            <label for="cust-name">Full name *</label>
            <input type="text" id="cust-name" required autocomplete="name">
          </div>
          <div class="form-group">
            <label for="cust-email">Email *</label>
            <input type="email" id="cust-email" required autocomplete="email">
          </div>
          <div class="form-group">
            <label for="cust-phone">Contact number *</label>
            <input type="tel" id="cust-phone" required autocomplete="tel">
          </div>
          <div class="form-group">
            <label for="cust-address">Delivery address *</label>
            <textarea id="cust-address" required autocomplete="street-address" placeholder="Address line, city, postcode"></textarea>
          </div>
        </div>
      </details>
      <div class="cart-subtotal">
        <span class="cart-subtotal__label">Subtotal</span>
        <span class="cart-subtotal__amount" id="cart-total">£0.00</span>
      </div>
      <a href="/cart" class="btn btn-primary cart-checkout-btn" style="text-align:center;text-decoration:none;">
        Checkout →
      </a>
      <p class="cart-secure">🔒 Secure checkout via Stripe · Free returns · Plastic-free packaging</p>
    </div>
  </div>

  <!-- Toast -->
  <div class="toast" id="toast" role="status" aria-live="polite"></div>

  <script type="application/json" id="search-data" set:html={JSON.stringify(searchProducts)} />

  <!-- Logout confirmation modal -->
  <div class="modal-overlay" id="logout-modal" hidden>
    <div class="modal-box" role="alertdialog" aria-modal="true" aria-labelledby="logout-modal-title">
      <p id="logout-modal-title" class="modal-box__title">Do you wish to sign out of your One Earth Beyond account?</p>
      <div class="modal-box__actions">
        <button type="button" class="btn btn-ghost" id="logout-cancel">Cancel</button>
        <button type="button" class="btn btn-danger" id="logout-confirm">Yes, Logout</button>
      </div>
    </div>
  </div>

  <!-- Main content -->
  <main id="main" tabindex="-1">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="site-footer" role="contentinfo">
    <div class="container">
      <div class="site-footer__grid">
        <div class="footer-col">
          <div class="footer-logo">
            <img src="/Logo/logo.png" alt="One Earth Gifting" class="footer-logo-img">
          </div>
          <p>Sustainably sourced gifts for people who care. Curated with love, packaged with purpose.</p>
          <div class="footer-certs">
            <span class="cert">1 Tree Per Order</span>
            <span class="cert">Plastic-Free</span>
            <span class="cert">B Corp Journey</span>
            <span class="cert">GOTS</span>
          </div>
          <p class="footer-parent">
            A venture of <a href="https://oneearthbeyond.com" target="_blank" rel="noopener">oneearthbeyond.com</a>
          </p>
        </div>
        <div class="footer-col">
          <h3 class="footer-col__heading">Shop</h3>
          <nav class="footer-links" aria-label="Shop links">
            <a href="/shop">All Products</a>
            <a href="/shop?cat=home-living">Home and Living</a>
            <a href="/shop?cat=stationery">Stationery</a>
            <a href="/shop?cat=gift-sets">Gift Sets</a>
          </nav>
        </div>
        <div class="footer-col">
          <h3 class="footer-col__heading">Corporate</h3>
          <nav class="footer-links" aria-label="Corporate links">
            <a href="/corporate">Corporate Gifting</a>
            <a href="/corporate#pricing">Volume Pricing</a>
            <a href="/corporate#branding">Custom Branding</a>
            <a href="/corporate#enquiry">Get a Quote</a>
          </nav>
        </div>
        <div class="footer-col">
          <h3 class="footer-col__heading">Information</h3>
          <nav class="footer-links" aria-label="Information links">
            <a href="/about">About Us</a>
            <a href="/about#sustainability">Sustainability</a>
            <a href="/delivery">Delivery &amp; Returns</a>
            <a href="/privacy">Privacy Policy</a>
            <a href="/terms">Terms of Service</a>
          </nav>
        </div>
      </div>
      <div class="site-footer__bottom">
        <span>© {new Date().getFullYear()} One Earth Beyond Ltd</span>
        <span class="footer-dot">·</span>
        <span>oneearthgifting.com</span>
        <span class="footer-dot">·</span>
        <span>A venture of <a href="https://oneearthbeyond.com" target="_blank" rel="noopener">oneearthbeyond.com</a></span>
        <span class="footer-dot">·</span>
        <a href="/privacy">Privacy</a>
        <span class="footer-dot">·</span>
        <a href="/terms">Terms</a>
      </div>
    </div>
  </footer>

  <script>
    import { supabase } from '../lib/supabaseClient.js';

    // ── Helpers ──────────────────────────────────────
    const FREE_DELIVERY_THRESHOLD = 50;
    const $ = id => document.getElementById(id);
    function toast(msg, type = 'success') {
      const t = $('toast');
      if (!t) return;
      t.textContent = msg;
      t.className = `toast ${type}`;
      requestAnimationFrame(() => {
        t.classList.add('show');
        setTimeout(() => t.classList.remove('show'), 2800);
      });
    }
    function fmt(n) { return '£' + (n).toFixed(2).replace(/\.00$/,''); }

    // ── Header scroll ─────────────────────────────────
    const header = document.querySelector('.site-header');
    window.addEventListener('scroll', () => header?.classList.toggle('scrolled', window.scrollY > 10), { passive: true });

    // ── Mobile nav ────────────────────────────────────
    const overlay = $('overlay');
    const mobileNav = $('mobile-nav');
    function openNav() {
      $('menu-btn')?.classList.add('open');
      mobileNav?.classList.add('open');
      overlay?.classList.add('active');
      mobileNav?.setAttribute('aria-hidden','false');
      document.body.style.overflow = 'hidden';
    }
    function closeNav() {
      $('menu-btn')?.classList.remove('open');
      mobileNav?.classList.remove('open');
      overlay?.classList.remove('active');
      mobileNav?.setAttribute('aria-hidden','true');
      if (!$('cart-drawer')?.classList.contains('open')) document.body.style.overflow = '';
    }
    $('menu-btn')?.addEventListener('click', openNav);
    $('menu-close')?.addEventListener('click', closeNav);

    // ── Cart ──────────────────────────────────────────
    const CART_KEY = 'oeg_cart';
    let currentUserId = null;
    let currentUserEmail = null;
    function getCart() { try { return JSON.parse(localStorage.getItem(CART_KEY) || '[]'); } catch { return []; } }
    function saveCart(c) {
      try { localStorage.setItem(CART_KEY, JSON.stringify(c)); } catch {}
      if (currentUserId) pushCartToSupabase(currentUserId, c, getNote());
    }
    function getNote() { try { return localStorage.getItem('oeg_note') || ''; } catch { return ''; } }
    function saveNote(n) {
      try { localStorage.setItem('oeg_note', n); } catch {}
      if (currentUserId) pushCartToSupabase(currentUserId, getCart(), n);
    }

    async function pushCartToSupabase(userId, cart, note) {
      try {
        await supabase.from('carts').upsert({ user_id: userId, items: cart, note: note || '', updated_at: new Date().toISOString() });
      } catch {}
    }

    async function syncCartFromSupabase(userId) {
      try {
        const { data } = await supabase.from('carts').select('items, note').eq('user_id', userId).maybeSingle();
        const localCart = getCart();
        if (data && data.items && data.items.length > 0) {
          saveCartLocalOnly(data.items);
          saveNoteLocalOnly(data.note || '');
          updateBadge();
          renderCart();
        } else if (localCart.length > 0) {
          await pushCartToSupabase(userId, localCart, getNote());
        }
      } catch {}
    }
    function saveCartLocalOnly(c) { try { localStorage.setItem(CART_KEY, JSON.stringify(c)); } catch {} }
    function saveNoteLocalOnly(n) { try { localStorage.setItem('oeg_note', n); } catch {} }

    // ── Customer details (mandatory for checkout) ─────
    const CUSTOMER_KEY = 'oeg_customer';
    function getCustomer() { try { return JSON.parse(localStorage.getItem(CUSTOMER_KEY) || '{}'); } catch { return {}; } }
    function saveCustomer(c) { try { localStorage.setItem(CUSTOMER_KEY, JSON.stringify(c)); } catch {} }
    function loadCustomerForm() {
      const c = getCustomer();
      if ($('cust-name')) $('cust-name').value = c.name || '';
      if ($('cust-email')) $('cust-email').value = c.email || '';
      if ($('cust-phone')) $('cust-phone').value = c.phone || '';
      if ($('cust-address')) $('cust-address').value = c.address || '';
    }
    function readCustomerForm() {
      const customer = {
        name: $('cust-name')?.value.trim() || '',
        email: $('cust-email')?.value.trim() || '',
        phone: $('cust-phone')?.value.trim() || '',
        address: $('cust-address')?.value.trim() || '',
      };
      saveCustomer(customer);
      return customer;
    }
    function validateCustomer(customer) {
      if (!customer.name || !customer.email || !customer.phone || !customer.address) {
        toast('Please fill in your name, email, contact number and address', 'error');
        $('cust-details') && ($('cust-details').open = true);
        return false;
      }
      if (!/^\S+@\S+\.\S+$/.test(customer.email)) {
        toast('Please enter a valid email address', 'error');
        $('cust-details') && ($('cust-details').open = true);
        return false;
      }
      return true;
    }
    ['cust-name', 'cust-email', 'cust-phone', 'cust-address'].forEach(id => {
      document.getElementById(id)?.addEventListener('change', readCustomerForm);
    });

    function openCart() {
      $('cart-drawer')?.classList.add('open');
      overlay?.classList.add('active');
      document.body.style.overflow = 'hidden';
      renderCart();
      loadCustomerForm();
    }
    function closeCart() {
      $('cart-drawer')?.classList.remove('open');
      if (!mobileNav?.classList.contains('open')) {
        overlay?.classList.remove('active');
        document.body.style.overflow = '';
      }
    }
    $('cart-close')?.addEventListener('click', closeCart);
    overlay?.addEventListener('click', () => { closeNav(); closeCart(); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') { closeNav(); closeCart(); } });

    function updateBadge() {
      const count = getCart().reduce((s, i) => s + i.qty, 0);
      const badge = $('cart-count');
      if (badge) { badge.textContent = count; badge.dataset.count = count; }
    }

    function renderCart() {
      const cart = getCart();
      const body = $('cart-body');
      const totalEl = $('cart-total');
      if (!body) return;

      const total = cart.reduce((s, i) => s + i.price * i.qty, 0);
      const freeDeliveryUnlocked = total >= FREE_DELIVERY_THRESHOLD;
      const remaining = Math.max(0, FREE_DELIVERY_THRESHOLD - total);
      const pct = Math.min(100, (total / FREE_DELIVERY_THRESHOLD) * 100);
      const freeLabel = freeDeliveryUnlocked ? '🎉 You have free UK delivery!' : `${fmt(remaining)} more for free delivery`;

      const shippingHTML = `
        <div class="shipping-bar">
          <div class="shipping-bar__label"><span>${freeLabel}</span></div>
          <div class="shipping-bar__track"><div class="shipping-bar__fill" style="width:${pct}%"></div></div>
        </div>
        <div class="shipping-methods">
          <div class="shipping-method${freeDeliveryUnlocked ? '' : ' shipping-method--frozen'}">
            <span class="shipping-method__name">Free delivery over £50</span>
            <span class="shipping-method__price">${freeDeliveryUnlocked ? 'FREE' : 'Locked'}</span>
          </div>
          <div class="shipping-method">
            <span class="shipping-method__name">Standard delivery (3 to 5 working days)</span>
            <span class="shipping-method__price">£3.95</span>
          </div>
          <div class="shipping-method">
            <span class="shipping-method__name">Express delivery (1 to 2 working days)</span>
            <span class="shipping-method__price">£6.95</span>
          </div>
        </div>`;

      if (cart.length === 0) {
        body.innerHTML = shippingHTML + '<div class="cart-empty">Your cart is empty — Pick sustainable gifts for your loved ones!</div>';
        if (totalEl) totalEl.textContent = '£0.00';
        return;
      }

      const itemsHTML = cart.map(item => `
        <div class="cart-item" data-slug="${item.slug}">
          <img class="cart-item__img" src="${item.image}" alt="${item.name}" loading="lazy" onerror="this.style.display='none'">
          <div class="cart-item__details">
            <div class="cart-item__name">${item.name}</div>
            <div class="cart-item__price">${fmt(item.price * item.qty)}</div>
            <div class="cart-item__qty">
              <button class="qty-btn" data-action="dec" data-slug="${item.slug}" aria-label="Remove one">−</button>
              <span class="qty-val">${item.qty}</span>
              <button class="qty-btn" data-action="inc" data-slug="${item.slug}" aria-label="Add one">+</button>
            </div>
            <button class="cart-item__remove" data-slug="${item.slug}">Remove</button>
          </div>
        </div>`).join('');

      const giftHTML = `
        <div class="cart-gift">
          <label for="gift-msg">Gift message (optional)</label>
          <textarea id="gift-msg" placeholder="Add a personal message...">${getNote()}</textarea>
        </div>`;

      body.innerHTML = shippingHTML + itemsHTML + giftHTML;
      if (totalEl) totalEl.textContent = fmt(total);

      document.getElementById('gift-msg')?.addEventListener('change', e => saveNote(e.target.value));

      body.querySelectorAll('.qty-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const cart = getCart();
          const idx = cart.findIndex(i => i.slug === btn.dataset.slug);
          if (idx === -1) return;
          if (btn.dataset.action === 'inc') cart[idx].qty++;
          else cart[idx].qty--;
          if (cart[idx].qty <= 0) cart.splice(idx, 1);
          saveCart(cart);
          updateBadge();
          renderCart();
        });
      });

      body.querySelectorAll('.cart-item__remove').forEach(btn => {
        btn.addEventListener('click', () => {
          const cart = getCart().filter(i => i.slug !== btn.dataset.slug);
          saveCart(cart);
          updateBadge();
          renderCart();
        });
      });
    }

    // Add to cart (called from product pages)
    window.addToCart = function(product) {
      const cart = getCart();
      const idx = cart.findIndex(i => i.slug === product.slug);
      if (idx > -1) cart[idx].qty++;
      else cart.push({ ...product, qty: 1 });
      saveCart(cart);
      updateBadge();
      openCart();
      toast('Added to basket ✓');
    };


    // Wishlist
    const WL_KEY = 'oeg_wl';
    function getWL() { try { return JSON.parse(localStorage.getItem(WL_KEY) || '[]'); } catch { return []; } }
    function saveWL(l) { try { localStorage.setItem(WL_KEY, JSON.stringify(l)); } catch {} }
    window.toggleWishlist = function(slug, btn) {
      const wl = getWL();
      const i = wl.indexOf(slug);
      if (i > -1) { wl.splice(i, 1); btn?.classList.remove('active'); toast('Removed from wishlist'); }
      else { wl.push(slug); btn?.classList.add('active'); toast('Saved to wishlist ♥'); }
      saveWL(wl);
    };
    window.isWishlisted = slug => getWL().includes(slug);

    // ── Auth state (header account dropdown + cart sync) ────
    let isLoggedIn = false;
    function updateAccountLink(session) {
      const link = $('account-link');
      if (!link) return;
      isLoggedIn = !!session;
      link.setAttribute('aria-label', isLoggedIn ? 'My account' : 'Log in');
      link.setAttribute('aria-expanded', 'false');
      closeAccountDropdown();
    }
    function handleAuthChange(session) {
      updateAccountLink(session);
      const newUserId = session?.user?.id || null;
      currentUserEmail = session?.user?.email || null;
      if (newUserId && newUserId !== currentUserId) {
        currentUserId = newUserId;
        syncCartFromSupabase(currentUserId);
      } else if (!newUserId) {
        currentUserId = null;
      }
    }
    supabase.auth.getSession().then(({ data: { session } }) => handleAuthChange(session));
    supabase.auth.onAuthStateChange((_event, session) => handleAuthChange(session));

    // ── Account dropdown ─────────────────────────────────
    function closeAccountDropdown() {
      $('account-dropdown')?.classList.remove('open');
      $('account-link')?.setAttribute('aria-expanded', 'false');
    }
    function openAccountDropdown() {
      $('account-dropdown')?.classList.add('open');
      $('account-link')?.setAttribute('aria-expanded', 'true');
    }
    $('account-link')?.addEventListener('click', (e) => {
      if (!isLoggedIn) return; // let the default /login navigation happen
      // Logged in: the icon is a hover target, not a navigation link — clicking just toggles.
      e.preventDefault();
      const dropdown = $('account-dropdown');
      if (!dropdown?.classList.contains('open')) openAccountDropdown();
      else closeAccountDropdown();
    });
    $('account-menu')?.addEventListener('mouseenter', () => { if (isLoggedIn) openAccountDropdown(); });
    $('account-menu')?.addEventListener('mouseleave', () => { if (isLoggedIn) closeAccountDropdown(); });
    document.addEventListener('click', (e) => {
      if (!$('account-menu')?.contains(e.target)) closeAccountDropdown();
    });

    // ── Logout confirmation modal ────────────────────────
    function openLogoutModal() { $('logout-modal')?.removeAttribute('hidden'); }
    function closeLogoutModal() { $('logout-modal')?.setAttribute('hidden', ''); }
    $('logout-trigger')?.addEventListener('click', () => { closeAccountDropdown(); openLogoutModal(); });
    $('logout-cancel')?.addEventListener('click', closeLogoutModal);
    $('logout-confirm')?.addEventListener('click', async () => {
      await supabase.auth.signOut();
      window.location.href = '/';
    });

    // ── Search panel (expands inline, no page navigation) ──
    function closeSearchPanel() {
      $('search-panel')?.classList.remove('open');
      $('search-btn')?.setAttribute('aria-expanded', 'false');
    }
    function openSearchPanel() {
      $('search-panel')?.classList.add('open');
      $('search-btn')?.setAttribute('aria-expanded', 'true');
      $('search-input')?.focus();
    }
    $('search-btn')?.addEventListener('click', (e) => {
      e.stopPropagation();
      if ($('search-panel')?.classList.contains('open')) closeSearchPanel();
      else openSearchPanel();
    });
    document.addEventListener('click', (e) => {
      if (!$('search-menu')?.contains(e.target)) closeSearchPanel();
    });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeSearchPanel(); });

    function searchCardHTML(p) {
      const img = p.image
        ? `<img src="/images/${p.image}" alt="${p.name}" loading="lazy" width="60" height="60">`
        : `<div class="search-result__img-placeholder"></div>`;
      const label = p.comingSoon ? 'Coming Soon' : (p.preOrder ? 'Pre-order · £' + p.price.toFixed(2) : '£' + p.price.toFixed(2));
      return `
        <a href="/products/${p.slug}" class="search-result">
          ${img}
          <span class="search-result__info">
            <span class="search-result__name">${p.name}</span>
            <span class="search-result__price">${label}</span>
          </span>
        </a>`;
    }
    function renderSearch(query) {
      const resultsEl = $('search-results');
      const q = query.trim().toLowerCase();
      if (!q) { resultsEl.innerHTML = ''; return; }
      const searchData = JSON.parse($('search-data')?.textContent || '[]');
      const matches = searchData.filter(p => p.name.toLowerCase().includes(q) || p.category.toLowerCase().includes(q)).slice(0, 8);
      resultsEl.innerHTML = matches.length
        ? matches.map(searchCardHTML).join('')
        : `<p class="search-panel__empty">No results for "${query}"</p>`;
    }
    $('search-input')?.addEventListener('input', (e) => renderSearch(e.target.value));

    // Init
    updateBadge();

    // Expose openCart/updateBadge globally for product pages and the /cart page
    window.openCart = openCart;
    window.updateBadge = updateBadge;
  </script>
</body>
</html>
