---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
}
const {
  title = 'One Earth Gifting — Sustainable Gifts',
  description = 'Curated sustainable gifts for individuals and businesses. Ethically sourced, plastic free packaged. One tree planted with every order.',
  image = '/og-image.jpg',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#2D4A2D">

  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={canonical}>

  <!-- Open Graph -->
  <meta property="og:title"       content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image"       content={image}>
  <meta property="og:url"         content={canonical}>
  <meta property="og:type"        content="website">
  <meta property="og:site_name"   content="One Earth Gifting">

  <!-- Twitter card -->
  <meta name="twitter:card"        content="summary_large_image">
  <meta name="twitter:title"       content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image"       content={image}>

  <!-- Schema.org -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "One Earth Gifting",
    "url": "https://oneearthgifting.co.uk",
    "description": "Sustainable gifting for individuals and businesses",
    "parentOrganization": {
      "@type": "Organization",
      "name": "One Earth Beyond Ltd",
      "url": "https://oneearthbeyond.com"
    }
  }
  </script>

</head>
<body>
  <a href="#main" class="visually-hidden" style="position:fixed;top:1rem;left:1rem;z-index:9999;padding:0.5rem 1rem;background:var(--forest);color:#fff;border-radius:4px;font-family:var(--font-primary);">
    Skip to content
  </a>

  <slot name="before-header" />

  <!-- Header -->
  <header class="site-header" role="banner">
    <div class="container">
      <div class="site-header__inner">
        <button class="hamburger" aria-label="Open menu" aria-expanded="false" id="menu-btn">
          <span></span><span></span><span></span>
        </button>

        <a href="/" class="site-header__logo" aria-label="One Earth Gifting — Home">
          <img src="/Logo/logo.png" alt="One Earth Gifting" class="site-logo">
        </a>

        <nav class="site-nav" aria-label="Main navigation">
          <a href="/shop">Shop</a>
          <a href="/corporate">Corporate Gifting</a>
          <a href="/about#sustainability">Sustainability</a>
          <a href="/our-artist">Our Artists</a>
        </nav>

        <div class="header-actions">
          <a href="/search" class="icon-btn" aria-label="Search">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          </a>
          <button class="icon-btn" id="cart-btn" aria-label="Open basket" aria-haspopup="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            <span class="cart-badge" id="cart-count" data-count="0" aria-label="items in basket">0</span>
          </button>
          <a href="/corporate" class="btn btn-terracotta btn-sm header-cta">Corporate Enquiry</a>
        </div>
      </div>
    </div>
  </header>

  <!-- Mobile Nav -->
  <nav class="mobile-nav" id="mobile-nav" aria-hidden="true" aria-label="Mobile navigation">
    <div class="mobile-nav__top">
      <img src="/Logo/logo.png" alt="One Earth Gifting" class="site-logo">
      <button class="icon-btn" id="menu-close" aria-label="Close menu">✕</button>
    </div>
    <div class="mobile-nav__links">
      <a href="/shop">Shop</a>
      <a href="/corporate">Corporate Gifting</a>
      <a href="/about#sustainability">Sustainability</a>
      <a href="/our-artist">Our Artists</a>
    </div>
    <div class="mobile-nav__cta">
      <a href="/corporate" class="btn btn-terracotta" style="width:100%;justify-content:center;">Corporate Enquiry</a>
    </div>
  </nav>

  <!-- Overlay -->
  <div class="overlay" id="overlay" aria-hidden="true"></div>

  <!-- Cart Drawer -->
  <div class="cart-drawer" id="cart-drawer" role="dialog" aria-modal="true" aria-label="Your basket">
    <div class="cart-drawer__header">
      <span class="cart-drawer__title">Your Basket</span>
      <button class="cart-drawer__close" id="cart-close" aria-label="Close basket">✕</button>
    </div>
    <div class="cart-drawer__body" id="cart-body">
      <div class="cart-empty">Your basket is empty</div>
    </div>
    <div class="cart-drawer__footer">
      <div class="cart-subtotal">
        <span class="cart-subtotal__label">Subtotal</span>
        <span class="cart-subtotal__amount" id="cart-total">£0.00</span>
      </div>
      <button class="btn btn-primary cart-checkout-btn" id="checkout-btn">
        Checkout Securely →
      </button>
      <p class="cart-secure">🔒 Secure checkout via Stripe · Free returns · Plastic-free packaging</p>
    </div>
  </div>

  <!-- Toast -->
  <div class="toast" id="toast" role="status" aria-live="polite"></div>

  <!-- Main content -->
  <main id="main" tabindex="-1">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="site-footer" role="contentinfo">
    <div class="container">
      <div class="site-footer__grid">
        <div class="footer-col">
          <div class="footer-logo">
            <img src="/Logo/logo.png" alt="One Earth Gifting" class="footer-logo-img">
          </div>
          <p>Sustainably sourced gifts for people who care. Curated with love, packaged with purpose.</p>
          <div class="footer-certs">
            <span class="cert">1 Tree Per Order</span>
            <span class="cert">Plastic-Free</span>
            <span class="cert">B Corp Journey</span>
            <span class="cert">GOTS</span>
          </div>
          <p class="footer-parent">
            A venture of <a href="https://oneearthbeyond.com" target="_blank" rel="noopener">oneearthbeyond.com</a>
          </p>
        </div>
        <div class="footer-col">
          <h3 class="footer-col__heading">Shop</h3>
          <nav class="footer-links" aria-label="Shop links">
            <a href="/shop">All Products</a>
            <a href="/shop?cat=home-living">Home and Living</a>
            <a href="/shop?cat=stationery">Stationery</a>
            <a href="/shop?cat=gift-sets">Gift Sets</a>
          </nav>
        </div>
        <div class="footer-col">
          <h3 class="footer-col__heading">Corporate</h3>
          <nav class="footer-links" aria-label="Corporate links">
            <a href="/corporate">Corporate Gifting</a>
            <a href="/corporate#pricing">Volume Pricing</a>
            <a href="/corporate#branding">Custom Branding</a>
            <a href="/corporate#enquiry">Get a Quote</a>
          </nav>
        </div>
        <div class="footer-col">
          <h3 class="footer-col__heading">Information</h3>
          <nav class="footer-links" aria-label="Information links">
            <a href="/about">About Us</a>
            <a href="/about#sustainability">Sustainability</a>
            <a href="/delivery">Delivery &amp; Returns</a>
            <a href="/privacy">Privacy Policy</a>
            <a href="/terms">Terms of Service</a>
          </nav>
        </div>
      </div>
      <div class="site-footer__bottom">
        <span>© {new Date().getFullYear()} One Earth Beyond Ltd</span>
        <span class="footer-dot">·</span>
        <span>oneearthgifting.co.uk</span>
        <span class="footer-dot">·</span>
        <span>A venture of <a href="https://oneearthbeyond.com" target="_blank" rel="noopener">oneearthbeyond.com</a></span>
        <span class="footer-dot">·</span>
        <a href="/privacy">Privacy</a>
        <span class="footer-dot">·</span>
        <a href="/terms">Terms</a>
      </div>
    </div>
  </footer>

  <script>
    // ── Helpers ──────────────────────────────────────
    const FREE_QTY = 20;
    const $ = id => document.getElementById(id);
    function toast(msg, type = 'success') {
      const t = $('toast');
      if (!t) return;
      t.textContent = msg;
      t.className = `toast ${type}`;
      requestAnimationFrame(() => {
        t.classList.add('show');
        setTimeout(() => t.classList.remove('show'), 2800);
      });
    }
    function fmt(n) { return '£' + (n).toFixed(2).replace(/\.00$/,''); }

    // ── Header scroll ─────────────────────────────────
    const header = document.querySelector('.site-header');
    window.addEventListener('scroll', () => header?.classList.toggle('scrolled', window.scrollY > 10), { passive: true });

    // ── Mobile nav ────────────────────────────────────
    const overlay = $('overlay');
    const mobileNav = $('mobile-nav');
    function openNav() {
      $('menu-btn')?.classList.add('open');
      mobileNav?.classList.add('open');
      overlay?.classList.add('active');
      mobileNav?.setAttribute('aria-hidden','false');
      document.body.style.overflow = 'hidden';
    }
    function closeNav() {
      $('menu-btn')?.classList.remove('open');
      mobileNav?.classList.remove('open');
      overlay?.classList.remove('active');
      mobileNav?.setAttribute('aria-hidden','true');
      if (!$('cart-drawer')?.classList.contains('open')) document.body.style.overflow = '';
    }
    $('menu-btn')?.addEventListener('click', openNav);
    $('menu-close')?.addEventListener('click', closeNav);

    // ── Cart ──────────────────────────────────────────
    const CART_KEY = 'oeg_cart';
    function getCart() { try { return JSON.parse(localStorage.getItem(CART_KEY) || '[]'); } catch { return []; } }
    function saveCart(c) { try { localStorage.setItem(CART_KEY, JSON.stringify(c)); } catch {} }
    function getNote() { try { return localStorage.getItem('oeg_note') || ''; } catch { return ''; } }
    function saveNote(n) { try { localStorage.setItem('oeg_note', n); } catch {} }

    function openCart() {
      $('cart-drawer')?.classList.add('open');
      overlay?.classList.add('active');
      document.body.style.overflow = 'hidden';
      renderCart();
    }
    function closeCart() {
      $('cart-drawer')?.classList.remove('open');
      if (!mobileNav?.classList.contains('open')) {
        overlay?.classList.remove('active');
        document.body.style.overflow = '';
      }
    }
    $('cart-btn')?.addEventListener('click', openCart);
    $('cart-close')?.addEventListener('click', closeCart);
    overlay?.addEventListener('click', () => { closeNav(); closeCart(); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') { closeNav(); closeCart(); } });

    function updateBadge() {
      const count = getCart().reduce((s, i) => s + i.qty, 0);
      const badge = $('cart-count');
      if (badge) { badge.textContent = count; badge.dataset.count = count; }
    }

    function renderCart() {
      const cart = getCart();
      const body = $('cart-body');
      const totalEl = $('cart-total');
      if (!body) return;

      const total = cart.reduce((s, i) => s + i.price * i.qty, 0);
      const totalQty = cart.reduce((s, i) => s + i.qty, 0);
      const remaining = Math.max(0, FREE_QTY - totalQty);
      const pct = Math.min(100, (totalQty / FREE_QTY) * 100);
      const freeLabel = remaining === 0 ? '🎉 You have free UK delivery!' : `${remaining} more item${remaining !== 1 ? 's' : ''} for free delivery`;

      const shippingHTML = `
        <div class="shipping-bar">
          <div class="shipping-bar__label"><span>${freeLabel}</span></div>
          <div class="shipping-bar__track"><div class="shipping-bar__fill" style="width:${pct}%"></div></div>
        </div>`;

      if (cart.length === 0) {
        body.innerHTML = shippingHTML + '<div class="cart-empty">Your basket is empty</div>';
        if (totalEl) totalEl.textContent = '£0.00';
        return;
      }

      const itemsHTML = cart.map(item => `
        <div class="cart-item" data-slug="${item.slug}">
          <img class="cart-item__img" src="${item.image}" alt="${item.name}" loading="lazy" onerror="this.style.display='none'">
          <div class="cart-item__details">
            <div class="cart-item__name">${item.name}</div>
            <div class="cart-item__price">${fmt(item.price * item.qty)}</div>
            <div class="cart-item__qty">
              <button class="qty-btn" data-action="dec" data-slug="${item.slug}" aria-label="Remove one">−</button>
              <span class="qty-val">${item.qty}</span>
              <button class="qty-btn" data-action="inc" data-slug="${item.slug}" aria-label="Add one">+</button>
            </div>
            <button class="cart-item__remove" data-slug="${item.slug}">Remove</button>
          </div>
        </div>`).join('');

      const giftHTML = `
        <div class="cart-gift">
          <label for="gift-msg">Gift message (optional)</label>
          <textarea id="gift-msg" placeholder="Add a personal message...">${getNote()}</textarea>
        </div>`;

      body.innerHTML = shippingHTML + itemsHTML + giftHTML;
      if (totalEl) totalEl.textContent = fmt(total);

      document.getElementById('gift-msg')?.addEventListener('change', e => saveNote(e.target.value));

      body.querySelectorAll('.qty-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const cart = getCart();
          const idx = cart.findIndex(i => i.slug === btn.dataset.slug);
          if (idx === -1) return;
          if (btn.dataset.action === 'inc') cart[idx].qty++;
          else cart[idx].qty--;
          if (cart[idx].qty <= 0) cart.splice(idx, 1);
          saveCart(cart);
          updateBadge();
          renderCart();
        });
      });

      body.querySelectorAll('.cart-item__remove').forEach(btn => {
        btn.addEventListener('click', () => {
          const cart = getCart().filter(i => i.slug !== btn.dataset.slug);
          saveCart(cart);
          updateBadge();
          renderCart();
        });
      });
    }

    // Add to cart (called from product pages)
    window.addToCart = function(product) {
      const cart = getCart();
      const idx = cart.findIndex(i => i.slug === product.slug);
      if (idx > -1) cart[idx].qty++;
      else cart.push({ ...product, qty: 1 });
      saveCart(cart);
      updateBadge();
      openCart();
      toast('Added to basket ✓');
    };

    // Checkout — POST to Stripe
    $('checkout-btn')?.addEventListener('click', async () => {
      const cart = getCart();
      if (cart.length === 0) { toast('Your basket is empty', 'error'); return; }
      const btn = $('checkout-btn');
      btn.disabled = true;
      btn.textContent = 'Redirecting to checkout…';
      try {
        const res = await fetch('/api/create-checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: cart, note: getNote() }),
        });
        const { url, error } = await res.json();
        if (url) window.location.href = url;
        else { toast(error || 'Checkout failed — please try again', 'error'); btn.disabled = false; btn.textContent = 'Checkout Securely →'; }
      } catch {
        toast('Network error — please try again', 'error');
        btn.disabled = false;
        btn.textContent = 'Checkout Securely →';
      }
    });

    // Wishlist
    const WL_KEY = 'oeg_wl';
    function getWL() { try { return JSON.parse(localStorage.getItem(WL_KEY) || '[]'); } catch { return []; } }
    function saveWL(l) { try { localStorage.setItem(WL_KEY, JSON.stringify(l)); } catch {} }
    window.toggleWishlist = function(slug, btn) {
      const wl = getWL();
      const i = wl.indexOf(slug);
      if (i > -1) { wl.splice(i, 1); btn?.classList.remove('active'); toast('Removed from wishlist'); }
      else { wl.push(slug); btn?.classList.add('active'); toast('Saved to wishlist ♥'); }
      saveWL(wl);
    };
    window.isWishlisted = slug => getWL().includes(slug);

    // Init
    updateBadge();

    // Expose openCart globally for product pages
    window.openCart = openCart;
  </script>
</body>
</html>
