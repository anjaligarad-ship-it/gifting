{
  "name": "oeg-website",
  "type": "module",
  "version": "1.0.0",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "test": "vitest run --config vitest.config.js",
    "test:unit": "vitest run --config vitest.config.js",
    "test:unit:coverage": "vitest run --config vitest.config.js --coverage",
    "test:component": "vitest run --config vitest.component.config.js",
    "test:e2e": "playwright test",
    "test:all": "npm run test:unit && npm run test:component",
    "test:watch": "vitest --config vitest.config.js"
  },
  "dependencies": {
    "@astrojs/vercel": "^7.0.0",
    "@supabase/supabase-js": "^2.108.2",
    "astro": "^4.0.0",
    "pg": "^8.22.0",
    "stripe": "^14.0.0",
    "twilio": "^6.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@vitest/coverage-v8": "^4.1.10",
    "happy-dom": "^20.10.6",
    "playwright": "^1.61.1",
    "vitest": "^4.1.10"
  }
}
