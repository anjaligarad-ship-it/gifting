# Copy this file to .env and fill in your real keys
# Never commit .env to git

# Stripe — get these from dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Your domain (used for redirect URLs)
PUBLIC_SITE_URL=https://oneearthgifting.com

# Resend — get this from resend.com (used to email order confirmations)
RESEND_API_KEY=re_...
# Internal address that receives full order + customer details
ORDER_NOTIFICATION_EMAIL=anjali.garad@oneearthbeyond.com

# Supabase — get these from supabase.com Project Settings > API
# DATABASE_URL is from Settings > Database > Connect (URI), used only by admin/seed scripts
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxx.supabase.co:5432/postgres
PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Twilio Verify — phone OTP for the FIRST first-order discount
# TWILIO_ACCOUNT_SID + TWILIO_AUTH_TOKEN: console.twilio.com → Account → API keys & tokens
# TWILIO_VERIFY_SERVICE_SID: console.twilio.com → Verify → Services → Create service → copy VA... SID
# Note: trial accounts can only send SMS to verified caller IDs (add numbers at console.twilio.com/phone-numbers/verified)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
